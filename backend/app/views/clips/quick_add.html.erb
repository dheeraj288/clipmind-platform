<div class="mx-auto max-w-3xl">

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-white">
      Quick Add Clip
    </h1>

    <p class="mt-2 text-slate-400">
      Save text, code or links instantly
    </p>
  </div>

 	<%= form_with model: @clip, url: clips_path, method: :post, data: { turbo: false } do |f| %>

    <div class="space-y-6 rounded-3xl border border-slate-800 bg-slate-900 p-8">

      <div>
        <%= f.label :title,
            class:"mb-2 block text-sm text-slate-300" %>

        <%= f.text_field :title,
            class:"w-full rounded-xl border border-slate-700 bg-slate-950 p-4 text-white" %>
      </div>

      <div>
        <%= f.label :content,
            class:"mb-2 block text-sm text-slate-300" %>

        <%= f.text_area :content,
            rows:8,
            class:"w-full rounded-xl border border-slate-700 bg-slate-950 p-4 text-white" %>
      </div>

      <div>
        <%= f.label :clip_type,
            class:"mb-2 block text-sm text-slate-300" %>

        <%= f.select :clip_type,
            ["text","code","link"],
            {},
            class:"w-full rounded-xl border border-slate-700 bg-slate-950 p-4 text-white" %>
      </div>

      <%= f.submit "Save Clip",
          class:"w-full rounded-xl bg-fuchsia-600 py-4 font-semibold text-white hover:bg-fuchsia-500" %>

    </div>

  <% end %>

</div>