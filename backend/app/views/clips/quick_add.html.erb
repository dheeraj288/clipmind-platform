<div class="mx-auto max-w-3xl">

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-white">
      Quick Add Clip
    </h1>

    <p class="mt-2 text-slate-400">
      Paste anything. ClipMind will auto-detect text, code, link, JSON, email or command.
    </p>
  </div>

  <%= form_with model: @clip, url: clips_path, method: :post, data: { turbo: false } do |f| %>

    <div class="space-y-6 rounded-3xl border border-slate-800 bg-slate-900 p-8">

      <% if @clip.errors.any? %>
        <div class="rounded-2xl border border-red-500/20 bg-red-500/10 p-4 text-sm text-red-200">
          <%= @clip.errors.full_messages.to_sentence %>
        </div>
      <% end %>

      <div>
        <%= f.label :title, "Title optional",
            class: "mb-2 block text-sm text-slate-300" %>

        <%= f.text_field :title,
            placeholder: "Leave blank for smart title",
            class: "w-full rounded-xl border border-slate-700 bg-slate-950 p-4 text-white outline-none focus:border-fuchsia-500" %>
      </div>

      <div>
        <%= f.label :content,
            class: "mb-2 block text-sm text-slate-300" %>

        <%= f.text_area :content,
            rows: 10,
            placeholder: "Paste text, code, URL, JSON, email or terminal command...",
            class: "w-full rounded-xl border border-slate-700 bg-slate-950 p-4 font-mono text-sm text-white outline-none focus:border-fuchsia-500" %>
      </div>

      <div class="rounded-3xl border border-white/10 bg-white/[0.03] p-5">
        <%= f.label :attachments, "Attach files / images", class: "mb-3 block text-sm font-bold text-slate-200" %>

        <%= f.file_field :attachments,
            multiple: true,
            direct_upload: true,
            class: "block w-full cursor-pointer rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-slate-300 file:mr-4 file:rounded-xl file:border-0 file:bg-fuchsia-500/20 file:px-4 file:py-2 file:text-sm file:font-bold file:text-fuchsia-200 hover:bg-white/[0.05]" %>

        <p class="mt-2 text-xs text-slate-500">
          Supports images, PDFs, text files, and documents.
        </p>
      </div>

      <div>
        <%= f.label :collection_id, "Collection optional",
            class: "mb-2 block text-sm text-slate-300" %>

        <%= f.select :collection_id,
            options_from_collection_for_select(@collections, :id, :name, @clip.collection_id),
            { include_blank: "Auto collection" },
            class: "w-full rounded-xl border border-slate-700 bg-slate-950 p-4 text-white outline-none focus:border-fuchsia-500" %>
      </div>

      <div class="rounded-2xl border border-indigo-500/20 bg-indigo-500/10 p-4 text-sm leading-6 text-indigo-100">
        Clip type and language will be detected automatically.
      </div>

      <%= f.submit "Save Clip",
          class: "w-full cursor-pointer rounded-xl bg-fuchsia-600 py-4 font-semibold text-white hover:bg-fuchsia-500" %>

    </div>

  <% end %>

</div>