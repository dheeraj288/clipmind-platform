<%= turbo_stream_from "user_#{current_user.id}_clips" %>

<div class="space-y-6" data-controller="bulk-actions">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
    <div>
      <h1 class="text-3xl font-bold text-white">All Clips</h1>
      <p class="mt-1 text-sm text-slate-400">
        Search, filter, copy and manage your saved clipboard items.
      </p>
    </div>

    <div class="rounded-full border border-slate-800 bg-slate-900 px-4 py-2 text-sm text-slate-300">
      <%= pluralize(@clips.count, "clip") %>
    </div>
  </div>

  <%= form_with url: clips_path,
      method: :get,
      class: "rounded-3xl border border-slate-800 bg-slate-900 p-5",
      data: { turbo_frame: "clips_list" } do %>

    <div class="grid gap-4 lg:grid-cols-[1fr_220px_120px]">
      <%= text_field_tag :q,
          @query,
          placeholder: "Search clips...",
          class: "rounded-2xl border border-slate-700 bg-slate-950 px-4 py-3 text-sm text-white outline-none placeholder:text-slate-500 focus:border-indigo-500" %>

      <%= select_tag :filter,
          options_for_select([
            ["All Types", "all"],
            ["Text", "text"],
            ["Code", "code"],
            ["Link", "link"],
            ["Email", "email"],
            ["JSON", "json"],
            ["Command", "command"]
          ], @filter),
          class: "rounded-2xl border border-slate-700 bg-slate-950 px-4 py-3 text-sm text-white outline-none focus:border-indigo-500" %>

      <%= submit_tag "Search",
          class: "cursor-pointer rounded-2xl bg-indigo-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/30 hover:bg-indigo-400" %>
    </div>
  <% end %>

  <div class="flex flex-col gap-4 rounded-2xl border border-slate-800 bg-slate-900 p-4 lg:flex-row lg:items-center lg:justify-between">
    <label class="flex items-center gap-3 text-sm font-semibold text-slate-300">
      <input
        type="checkbox"
        data-action="change->bulk-actions#toggleAll"
        class="h-4 w-4 rounded border-slate-700 bg-slate-950 accent-fuchsia-600">

      Select all clips
    </label>

    <div
      data-bulk-actions-target="bar"
      class="hidden flex-wrap items-center gap-3 rounded-xl border border-fuchsia-500/20 bg-fuchsia-500/10 px-4 py-2">

      <span class="text-sm font-semibold text-fuchsia-200">
        <span data-bulk-actions-target="count">0</span> selected
      </span>

      <%= form_with url: bulk_favorite_clips_path,
          method: :patch,
          data: { turbo: false },
          class: "inline-block" do %>
        <%= hidden_field_tag :clip_ids, "", data: { bulk_actions_target: "clipIds" } %>

        <%= submit_tag "Favorite",
            class: "cursor-pointer rounded-lg border border-slate-700 px-3 py-1 text-xs font-semibold text-slate-300 hover:bg-slate-800" %>
      <% end %>

      <%= form_with url: bulk_pin_clips_path,
          method: :patch,
          data: { turbo: false },
          class: "inline-block" do %>
        <%= hidden_field_tag :clip_ids, "", data: { bulk_actions_target: "clipIds" } %>

        <%= submit_tag "Pin",
            class: "cursor-pointer rounded-lg border border-slate-700 px-3 py-1 text-xs font-semibold text-slate-300 hover:bg-slate-800" %>
      <% end %>

      <%= form_with url: bulk_delete_clips_path,
          method: :delete,
          data: {
            turbo: false,
            turbo_confirm: "Are you sure you want to delete selected clips?"
          },
          class: "inline-block" do %>
        <%= hidden_field_tag :clip_ids, "", data: { bulk_actions_target: "clipIds" } %>

        <%= submit_tag "Delete",
            class: "cursor-pointer rounded-lg border border-red-500/20 px-3 py-1 text-xs font-semibold text-red-300 hover:bg-red-500 hover:text-white" %>
      <% end %>
    </div>
  </div>

  <%= turbo_frame_tag "clips_list" do %>
    <div id="clips_list_items" class="grid gap-4">
      <% if @clips.any? %>
        <% @clips.each do |clip| %>
          <%= render "shared/clip_card", clip: clip %>
        <% end %>
      <% else %>
        <%= render "shared/empty_state",
            icon: "🔎",
            title: "No clips found",
            message: "Search ya filter change karke try karo." %>
      <% end %>
    </div>
  <% end %>
</div>