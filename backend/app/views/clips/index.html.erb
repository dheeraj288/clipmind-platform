<div class="space-y-6">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
    <div>
      <h1 class="text-3xl font-bold text-white">All Clips</h1>
      <p class="mt-1 text-sm text-slate-400">
        Search, filter, copy and manage your saved clipboard items.
      </p>
    </div>

    <div class="rounded-full border border-slate-800 bg-slate-900 px-4 py-2 text-sm text-slate-300">
      <%= pluralize(@clips.count, "clip") %>
    </div>
  </div>

  <%= form_with url: clips_path, method: :get, class: "rounded-3xl border border-slate-800 bg-slate-900 p-5", data: { turbo_frame: "clips_list" } do %>
    <div class="grid gap-4 lg:grid-cols-[1fr_220px_120px]">
      <%= text_field_tag :q, @query, placeholder: "Search clips...",
          class: "rounded-2xl border border-slate-700 bg-slate-950 px-4 py-3 text-sm text-white outline-none placeholder:text-slate-500 focus:border-indigo-500" %>

      <%= select_tag :filter,
          options_for_select([
            ["All Types", "all"],
            ["Text", "text"],
            ["Code", "code"],
            ["Link", "link"],
            ["Email", "email"],
            ["JSON", "json"],
            ["Command", "command"]
          ], @filter),
          class: "rounded-2xl border border-slate-700 bg-slate-950 px-4 py-3 text-sm text-white outline-none focus:border-indigo-500" %>

      <%= submit_tag "Search",
          class: "cursor-pointer rounded-2xl bg-indigo-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/30 hover:bg-indigo-400" %>
    </div>
  <% end %>

  <%= turbo_frame_tag "clips_list" do %>
    <div class="grid gap-4">
      <% if @clips.any? %>
        <% @clips.each do |clip| %>
          <%= render "shared/clip_card", clip: clip %>
        <% end %>
      <% else %>
        <%= render "shared/empty_state",
            icon: "🔎",
            title: "No clips found",
            message: "Search ya filter change karke try karo." %>
      <% end %>
    </div>
  <% end %>
</div>