<% if clip.pending? || clip.processing? %>

  <div class="inline-flex items-center gap-2 rounded-full border border-yellow-500/20 bg-yellow-500/10 px-3 py-1 text-[10px] text-yellow-300">

    <div class="h-2 w-2 rounded-full bg-yellow-400 animate-pulse"></div>

    Generating...

  </div>

<% elsif clip.completed? %>

  <div class="inline-flex items-center gap-2 rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1 text-[10px] text-emerald-300">

    <div class="h-2 w-2 rounded-full bg-emerald-400"></div>

    Completed

  </div>

<% elsif clip.failed? %>

  <div class="inline-flex items-center gap-2 rounded-full border border-red-500/20 bg-red-500/10 px-3 py-1 text-[10px] text-red-300">

    <div class="h-2 w-2 rounded-full bg-red-400"></div>

    Failed

  </div>

<% end %>