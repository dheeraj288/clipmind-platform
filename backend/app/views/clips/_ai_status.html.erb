<% status = clip.reload.ai_status.presence || "pending" %>

<% if status.in?(["pending","processing"]) %>

  <span class="inline-flex items-center gap-2 rounded-full border border-yellow-500/20 bg-yellow-500/10 px-3 py-1 text-[10px] text-yellow-300">

    <span class="h-2 w-2 rounded-full bg-yellow-400 animate-pulse"></span>

    Generating...

  </span>

<% elsif status=="completed" %>

  <span class="inline-flex items-center gap-2 rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1 text-[10px] text-emerald-300">

    <span class="h-2 w-2 rounded-full bg-emerald-400"></span>

    Completed

  </span>

<% elsif status=="failed" %>

  <span class="inline-flex items-center gap-2 rounded-full border border-red-500/20 bg-red-500/10 px-3 py-1 text-[10px] text-red-300">

    <span class="h-2 w-2 rounded-full bg-red-400"></span>

    Failed

  </span>

<% end %>