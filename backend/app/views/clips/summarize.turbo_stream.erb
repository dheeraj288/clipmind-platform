<%= turbo_stream.update "clip_summary_#{@clip.id}" do %>
  <div class="mt-5 overflow-hidden rounded-3xl border border-emerald-400/20 bg-slate-950/90 shadow-2xl shadow-emerald-950/40 backdrop-blur-xl">

    <div class="border-b border-white/10 bg-gradient-to-r from-emerald-500/15 via-cyan-500/10 to-violet-500/15 px-5 py-4">
      <div class="flex items-start justify-between gap-4">
        <div class="flex items-start gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-2xl border border-emerald-400/30 bg-emerald-400/10 text-lg shadow-lg shadow-emerald-950/40">
            ✨
          </div>

          <div>
            <p class="text-[11px] font-black uppercase tracking-[0.25em] text-emerald-300">
              ClipMind AI
            </p>
            <h4 class="mt-1 text-base font-black text-white">
              Smart Summary
            </h4>
            <p class="mt-1 text-xs text-slate-400">
              Cached summary · Gemini AI
            </p>
          </div>
        </div>

        <div class="flex items-center gap-2">
          <button
            type="button"
            data-controller="copy-summary"
            data-copy-summary-text-value="<%= h(@summary) %>"
            data-action="click->copy-summary#copy"
            class="rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-2 text-xs font-bold text-emerald-200 transition hover:bg-emerald-400/20 hover:text-white">
            📋 Copy
          </button>

          <%= button_to hide_summary_clip_path(@clip),
              method: :post,
              title: "Close summary",
              class: "rounded-full border border-white/10 bg-white/5 px-3 py-2 text-xs font-black text-slate-300 transition hover:bg-white/10 hover:text-white" do %>
            ✕
          <% end %>
        </div>
      </div>
    </div>

    <div class="p-5">
      <div class="rounded-2xl border border-white/10 bg-black/25 p-4 text-sm leading-7 text-slate-100">
        <div class="whitespace-pre-wrap"><%= @summary %></div>
      </div>

      <div class="mt-4 flex flex-wrap items-center gap-2">
        <%= button_to save_ai_memory_clip_path(@clip),
            method: :post,
            class: "rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-xs font-bold text-cyan-200 transition hover:bg-cyan-400/20 hover:text-white" do %>
          ⭐ Save Memory
        <% end %>

        <%= button_to regenerate_summary_clip_path(@clip),
            method: :post,
            class: "rounded-full border border-amber-400/20 bg-amber-400/10 px-4 py-2 text-xs font-bold text-amber-200 transition hover:bg-amber-400/20 hover:text-white" do %>
          🔄 Regenerate
        <% end %>

        <% if @clip.ai_summary_generated_at.present? %>
          <span class="ml-auto rounded-full border border-white/10 bg-white/5 px-3 py-2 text-[11px] font-semibold text-slate-400">
            Generated <%= time_ago_in_words(@clip.ai_summary_generated_at) %> ago
          </span>
        <% end %>
      </div>
    </div>
  </div>
<% end %>