<%= turbo_stream.update "clip_summary_#{@clip.id}" do %>
  <div class="mt-4 rounded-3xl border border-emerald-400/20 bg-gradient-to-br from-emerald-500/15 via-slate-900/80 to-cyan-500/10 p-5 shadow-2xl shadow-emerald-950/30">
    <div class="mb-3 flex items-center justify-between gap-3">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.22em] text-emerald-300">
          ClipMind AI
        </p>
        <h4 class="mt-1 text-sm font-bold text-white">
          Smart Summary
        </h4>
      </div>

      <span class="rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-xs font-bold text-emerald-200">
        ✨ AI
      </span>
    </div>

    <div class="whitespace-pre-wrap rounded-2xl border border-white/10 bg-black/20 p-4 text-sm leading-7 text-slate-100">
      <%= @summary %>
    </div>
  </div>
<% end %>