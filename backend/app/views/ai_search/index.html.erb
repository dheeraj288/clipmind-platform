<div class="space-y-8">

  <section class="rounded-3xl border border-fuchsia-500/20 bg-gradient-to-br from-fuchsia-950/40 to-cyan-950/20 p-8">

    <div class="max-w-3xl">
      <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-fuchsia-500/20 text-fuchsia-300">
        <%= render "shared/sidebar_icon", name: "search" %>
      </div>

      <h1 class="text-3xl font-bold text-white">
        AI Search
      </h1>

      <p class="mt-3 text-sm leading-6 text-slate-400">
        Search your clipboard workspace by meaning, keywords, clip type, commands, snippets and notes.
      </p>
    </div>

    <%= form_with url: ai_search_path,
        method: :get,
        local: true,
        class: "mt-8 grid gap-4 lg:grid-cols-[1fr_140px]" do %>

      <%= text_field_tag :q,
          @query,
          placeholder: "Search anything... e.g. rails migration, jwt token, api endpoint",
          class: "rounded-2xl border border-slate-700 bg-slate-950 px-5 py-4 text-sm text-white outline-none placeholder:text-slate-500 focus:border-fuchsia-500" %>

      <%= submit_tag "Search",
          class: "cursor-pointer rounded-2xl bg-fuchsia-600 px-5 py-4 text-sm font-semibold text-white shadow-lg shadow-fuchsia-600/30 hover:bg-fuchsia-500" %>

    <% end %>

  </section>


  <% if @query.present? %>

    <section class="flex items-center justify-between">
      <div>
        <h2 class="text-lg font-bold text-white">
          Search results
        </h2>

        <p class="mt-1 text-sm text-slate-400">
          Found <%= pluralize(@results.count, "result") %> for "<%= @query %>"
        </p>
      </div>
    </section>

    <% if @results.any? %>
      <section class="grid gap-4 xl:grid-cols-2">
        <% @results.each do |clip| %>
          <%= render "shared/clip_card", clip: clip %>
        <% end %>
      </section>
    <% else %>
      <%= render "shared/empty_state",
          icon: "🔎",
          title: "No matching clips",
          message: "Try another keyword like rails, command, api, token, error." %>
    <% end %>

  <% else %>

    <section class="grid gap-4 md:grid-cols-3">

      <div class="rounded-2xl border border-slate-800 bg-slate-900 p-5">
        <h3 class="font-bold text-white">Try searching</h3>
        <p class="mt-2 text-sm text-slate-400">rails migration</p>
        <p class="mt-1 text-sm text-slate-400">jwt auth</p>
        <p class="mt-1 text-sm text-slate-400">api endpoint</p>
      </div>

      <div class="rounded-2xl border border-slate-800 bg-slate-900 p-5">
        <h3 class="font-bold text-white">Search supports</h3>
        <p class="mt-2 text-sm text-slate-400">Title</p>
        <p class="mt-1 text-sm text-slate-400">Content</p>
        <p class="mt-1 text-sm text-slate-400">Clip type</p>
      </div>

      <div class="rounded-2xl border border-slate-800 bg-slate-900 p-5">
        <h3 class="font-bold text-white">Coming soon</h3>
        <p class="mt-2 text-sm text-slate-400">Semantic search</p>
        <p class="mt-1 text-sm text-slate-400">AI suggestions</p>
        <p class="mt-1 text-sm text-slate-400">Smart ranking</p>
      </div>

    </section>

  <% end %>

</div>