<div class="space-y-8">
  <section class="relative overflow-hidden rounded-[36px] border border-white/10 bg-white/[0.04] p-6 shadow-2xl shadow-black/20 backdrop-blur-xl lg:p-8">
    <div class="absolute -right-16 -top-16 h-60 w-60 rounded-full bg-fuchsia-500/15 blur-3xl"></div>
    <div class="absolute -bottom-20 left-1/4 h-60 w-60 rounded-full bg-cyan-400/10 blur-3xl"></div>

    <div class="relative max-w-3xl">
      <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-3xl border border-fuchsia-400/20 bg-fuchsia-500/10 text-fuchsia-200">
        <%= render "shared/sidebar_icon", name: "search" %>
      </div>
      <p class="text-xs font-black uppercase tracking-[0.28em] text-fuchsia-300">Context search</p>
      <h1 class="mt-2 bg-gradient-to-r from-white via-fuchsia-100 to-cyan-200 bg-clip-text text-3xl font-black tracking-tight text-transparent lg:text-5xl">AI Search</h1>
      <p class="mt-4 text-sm leading-6 text-slate-400">Search your clipboard workspace by meaning, keywords, clip type, commands, snippets and notes.</p>
    </div>

    <%= form_with url: ai_search_path, method: :get, local: true, class: "relative mt-8 grid gap-3 lg:grid-cols-[1fr_150px]" do %>
      <%= text_field_tag :q, @query,
          placeholder: "Search anything... rails migration, jwt token, api endpoint",
          class: "min-h-14 rounded-2xl border border-white/10 bg-slate-950/70 px-5 text-sm font-medium text-white outline-none placeholder:text-slate-500 transition focus:border-fuchsia-400/40 focus:ring-4 focus:ring-fuchsia-500/10" %>
      <%= submit_tag "Search", class: "min-h-14 cursor-pointer rounded-2xl bg-gradient-to-r from-fuchsia-600 to-indigo-600 px-5 text-sm font-black text-white shadow-lg shadow-fuchsia-950/30 transition hover:-translate-y-0.5" %>
    <% end %>
  </section>

  <% if @query.present? %>
    <section class="flex items-center justify-between">
      <div>
        <h2 class="text-xl font-black text-white">Search results</h2>
        <p class="mt-1 text-sm text-slate-400">Found <%= pluralize(@results.count, "result") %> for "<%= @query %>"</p>
      </div>
    </section>

    <% if @results.any? %>
      <section class="grid gap-5 xl:grid-cols-2">
        <% @results.each do |clip| %>
          <%= render "shared/clip_card", clip: clip %>
        <% end %>
      </section>
    <% else %>
      <%= render "shared/empty_state", icon: "🔎", title: "No matching clips", message: "Try another keyword like rails, command, api, token, error." %>
    <% end %>
  <% else %>
    <section class="grid gap-4 md:grid-cols-3">
      <% [["Try searching", ["rails migration", "jwt auth", "api endpoint"]], ["Search supports", ["Title", "Content", "Clip type"]], ["Coming soon", ["Semantic ranking", "AI suggestions", "Smart filters"]]].each do |title, items| %>
        <div class="rounded-[28px] border border-white/10 bg-white/[0.04] p-6 shadow-xl shadow-black/10 backdrop-blur-xl">
          <h3 class="font-black text-white"><%= title %></h3>
          <div class="mt-4 space-y-2">
            <% items.each do |item| %>
              <p class="rounded-xl bg-white/[0.04] px-3 py-2 text-sm text-slate-400"><%= item %></p>
            <% end %>
          </div>
        </div>
      <% end %>
    </section>
  <% end %>
</div>
