<div class="mx-auto max-w-4xl">

<h1 class="mb-6 text-3xl font-bold text-white">
AI Memory Chat
</h1>

<%= form_with url: ai_chat_path, data: { turbo: false } do |f| %>
<div class="flex gap-3">

<%= f.text_field :message,
class:"flex-1 rounded-2xl bg-slate-900 px-5 py-4 text-white",
placeholder:"Ask: What did I learn today?" %>

<%= f.submit "Ask",
class:"rounded-2xl bg-fuchsia-600 px-6 py-4 text-white" %>

</div>

<% end %>

<% if @response.present? %>

<div class="mt-8 rounded-3xl border border-fuchsia-500/20 p-6">

<pre class="whitespace-pre-wrap text-slate-300"><%= @response %></pre>

</div>

<% end %>

</div>