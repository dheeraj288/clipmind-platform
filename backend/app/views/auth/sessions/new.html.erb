<div class="flex min-h-screen items-center justify-center bg-slate-950 px-4">
  <div class="w-full max-w-md rounded-3xl border border-slate-800 bg-slate-900 p-8 shadow-2xl">
    <div class="mb-8 text-center">
      <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-fuchsia-600 text-2xl text-white">
        ✨
      </div>

      <h1 class="text-2xl font-bold text-white">Login to ClipMind</h1>

      <p class="mt-2 text-sm text-slate-400">
        Continue to your AI clipboard workspace.
      </p>
    </div>

    <% if flash[:alert].present? %>
      <div class="mb-4 rounded-xl border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-300">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= form_with url: login_path, method: :post, local: true, data: { turbo: false }, class: "space-y-4" do %>
      <div>
        <label class="mb-2 block text-sm font-medium text-slate-300">Email</label>

        <%= email_field_tag :email, nil,
            placeholder: "test@test.com",
            class: "w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-3 text-sm text-white outline-none placeholder:text-slate-500 focus:border-fuchsia-500" %>
      </div>

      <div>
        <label class="mb-2 block text-sm font-medium text-slate-300">Password</label>

        <%= password_field_tag :password, nil,
            placeholder: "••••••••",
            class: "w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-3 text-sm text-white outline-none placeholder:text-slate-500 focus:border-fuchsia-500" %>
      </div>

      <p class="mt-5 text-center text-sm text-slate-400">
        Don't have an account?

        <%= link_to "Sign up",
            signup_path,
            class: "text-fuchsia-400 hover:text-fuchsia-300" %>
      </p>

      <%= submit_tag "Login",
          class: "w-full cursor-pointer rounded-xl bg-fuchsia-600 px-4 py-3 text-sm font-semibold text-white shadow-lg shadow-fuchsia-600/30 hover:bg-fuchsia-500" %>
    <% end %>
  </div>
</div>