<div class="space-y-8">

  <div class="flex items-end justify-between">
    <div>
      <h1 class="text-3xl font-bold text-white">
        Prompt Vault
      </h1>

      <p class="mt-2 text-sm text-slate-400">
        Manage your AI prompt templates
      </p>
    </div>

    <button class="rounded-xl bg-fuchsia-600 px-5 py-3 text-sm font-semibold text-white hover:bg-fuchsia-500">
      + New Prompt
    </button>
  </div>


  <div class="flex gap-4">

    <input
      placeholder="Search prompts..."
      class="flex-1 rounded-xl border border-slate-800 bg-slate-800/70 px-4 py-3 text-white outline-none placeholder:text-slate-500"
    >

    <select class="w-48 rounded-xl border border-slate-800 bg-slate-800/70 px-4 text-white">

      <option>All Categories</option>
      <option>Code</option>
      <option>Debug</option>
      <option>Documentation</option>

    </select>

  </div>


  <div class="grid gap-5 xl:grid-cols-[360px_1fr]">
    <div class="space-y-3">
      <% prompts = [
        ["Code Review Assistant", "Review code for bugs, performance, and best practices", "Code Review", true],
        ["Bug Explainer", "Explain error messages and suggest fixes", "Debugging", false],
        ["API Documentation Generator", "Generate API documentation from code", "Documentation", true],
        ["Test Case Generator", "Generate unit tests for functions", "Testing", false]
      ] %>

      <% prompts.each do |title, desc, tag, favorite| %>
        <div class="cursor-pointer rounded-2xl border border-slate-800 bg-slate-900 p-4 transition hover:border-fuchsia-500/40">
          <div class="flex items-start justify-between gap-4">
            <div class="flex gap-3">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-fuchsia-500/10 text-sm text-fuchsia-400">
                ✨
              </div>

              <div>
                <h3 class="text-sm font-bold text-white">
                  <%= title %>
                </h3>

                <p class="mt-1 line-clamp-1 text-xs text-slate-400">
                  <%= desc %>
                </p>

                <span class="mt-3 inline-flex rounded-full bg-slate-800 px-3 py-1 text-xs text-slate-300">
                  <%= tag %>
                </span>
              </div>
            </div>

            <span class="<%= favorite ? 'text-fuchsia-500' : 'text-slate-500' %>">
              <%= favorite ? "★" : "☆" %>
            </span>
          </div>
        </div>
      <% end %>
    </div>

  <div class="flex min-h-[220px] items-center justify-center rounded-2xl border border-dashed border-slate-800 bg-slate-900">
    <div class="text-center">
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-slate-800 text-2xl text-slate-400">
        ✨
      </div>

      <h3 class="mt-5 text-lg font-bold text-white">
        Select a prompt
      </h3>

      <p class="mt-2 text-sm text-slate-400">
        Choose a prompt from the list to view and edit
      </p>
    </div>
  </div>
</div>

</div>