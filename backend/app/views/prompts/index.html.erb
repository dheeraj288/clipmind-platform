<div class="space-y-8">
  <section class="relative overflow-hidden rounded-[36px] border border-white/10 bg-white/[0.04] p-6 shadow-2xl shadow-black/20 backdrop-blur-xl lg:p-8">
    <div class="absolute -right-16 -top-16 h-56 w-56 rounded-full bg-fuchsia-500/15 blur-3xl"></div>
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.28em] text-fuchsia-300">Reusable AI workflows</p>
        <h1 class="mt-2 bg-gradient-to-r from-white via-fuchsia-100 to-cyan-200 bg-clip-text text-3xl font-black tracking-tight text-transparent lg:text-5xl">Prompt Vault</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-400">Manage reusable AI prompt templates for code review, debugging, documentation and testing.</p>
      </div>

      <button class="rounded-2xl bg-gradient-to-r from-fuchsia-600 to-indigo-600 px-5 py-3 text-sm font-black text-white shadow-lg shadow-fuchsia-950/30 transition hover:-translate-y-0.5">
        + New Prompt
      </button>
    </div>
  </section>

  <div class="grid gap-5 lg:grid-cols-[1fr_240px]">
    <input placeholder="Search prompts..." class="min-h-12 rounded-2xl border border-white/10 bg-white/[0.04] px-4 text-sm text-white outline-none placeholder:text-slate-500 focus:border-fuchsia-400/40">
    <select class="min-h-12 rounded-2xl border border-white/10 bg-white/[0.04] px-4 text-sm text-white outline-none focus:border-fuchsia-400/40">
      <option>All Categories</option>
      <option>Code</option>
      <option>Debug</option>
      <option>Documentation</option>
    </select>
  </div>

  <div class="grid gap-5 xl:grid-cols-[380px_1fr]">
    <div class="space-y-3">
      <% prompts = [["Code Review Assistant", "Review code for bugs, performance, and best practices", "Code Review", true], ["Bug Explainer", "Explain error messages and suggest fixes", "Debugging", false], ["API Documentation Generator", "Generate API documentation from code", "Documentation", true], ["Test Case Generator", "Generate unit tests for functions", "Testing", false]] %>
      <% prompts.each do |title, desc, tag, favorite| %>
        <div class="cursor-pointer rounded-[26px] border border-white/10 bg-white/[0.04] p-4 shadow-xl shadow-black/10 backdrop-blur-xl transition hover:-translate-y-1 hover:border-fuchsia-500/30 hover:bg-white/[0.06]">
          <div class="flex items-start justify-between gap-4">
            <div class="flex gap-3">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-fuchsia-500/10 text-sm text-fuchsia-300">✨</div>
              <div>
                <h3 class="text-sm font-black text-white"><%= title %></h3>
                <p class="mt-1 line-clamp-1 text-xs leading-5 text-slate-400"><%= desc %></p>
                <span class="mt-3 inline-flex rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs font-bold text-slate-300"><%= tag %></span>
              </div>
            </div>
            <span class="<%= favorite ? 'text-fuchsia-400' : 'text-slate-600' %>"><%= favorite ? "★" : "☆" %></span>
          </div>
        </div>
      <% end %>
    </div>

    <div class="flex min-h-[320px] items-center justify-center rounded-[30px] border border-dashed border-white/10 bg-white/[0.035] p-8 text-center shadow-xl shadow-black/10 backdrop-blur-xl">
      <div>
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-3xl bg-white/[0.06] text-3xl text-slate-400">✨</div>
        <h3 class="mt-5 text-xl font-black text-white">Select a prompt</h3>
        <p class="mt-2 text-sm text-slate-400">Choose a prompt from the list to view and edit.</p>
      </div>
    </div>
  </div>
</div>
