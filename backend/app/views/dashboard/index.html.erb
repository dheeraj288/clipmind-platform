<div class="space-y-8">
  <section class="relative overflow-hidden rounded-[36px] border border-white/10 bg-white/[0.04] p-6 shadow-2xl shadow-black/20 backdrop-blur-xl lg:p-8">
    <div class="absolute -right-16 -top-16 h-56 w-56 rounded-full bg-fuchsia-500/20 blur-3xl"></div>
    <div class="absolute -bottom-20 left-1/3 h-56 w-56 rounded-full bg-cyan-400/10 blur-3xl"></div>

    <div class="relative flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">
      <div class="max-w-3xl">
        <p class="text-xs font-black uppercase tracking-[0.28em] text-fuchsia-200">Today’s workspace</p>
        <h1 class="mt-3 bg-gradient-to-r from-white via-fuchsia-100 to-cyan-200 bg-clip-text text-3xl font-black tracking-tight text-transparent lg:text-5xl">
          Good evening, <%= current_user.email.split("@").first.titleize %> 👋
        </h1>
        <p class="mt-4 max-w-2xl text-sm leading-6 text-slate-400">
          Your clipboard is organized, searchable and AI-ready. Capture important code, links and ideas without losing context.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-3 sm:min-w-[360px]">
        <%= link_to quick_add_clips_path, class: "rounded-2xl border border-white/10 bg-white/[0.06] p-4 transition hover:bg-white/[0.1]" do %>
          <div class="text-2xl">＋</div>
          <p class="mt-2 text-sm font-black text-white">Quick Add</p>
          <p class="mt-1 text-xs text-slate-500">Save manually</p>
        <% end %>

        <%= link_to ai_search_path, class: "rounded-2xl border border-white/10 bg-white/[0.06] p-4 transition hover:bg-white/[0.1]" do %>
          <div class="text-2xl">⌕</div>
          <p class="mt-2 text-sm font-black text-white">AI Search</p>
          <p class="mt-1 text-xs text-slate-500">Find faster</p>
        <% end %>
      </div>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-[28px] border border-white/10 bg-white/[0.04] p-6 shadow-xl shadow-black/10 backdrop-blur-xl">
      <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-500">Total Clips</p>
      <p class="mt-3 text-4xl font-black text-white"><%= @total_clips %></p>
      <p class="mt-2 text-xs font-bold text-fuchsia-300">+<%= @memory_stats[:total] %> today</p>
    </div>

    <div class="rounded-[28px] border border-white/10 bg-white/[0.04] p-6 shadow-xl shadow-black/10 backdrop-blur-xl">
      <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-500">Collections</p>
      <p class="mt-3 text-4xl font-black text-white"><%= @collections_count %></p>
      <p class="mt-2 text-xs font-bold text-cyan-300">active spaces</p>
    </div>

    <div class="rounded-[28px] border border-white/10 bg-white/[0.04] p-6 shadow-xl shadow-black/10 backdrop-blur-xl">
      <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-500">Favorites</p>
      <p class="mt-3 text-4xl font-black text-white"><%= @favorite_clips %></p>
      <p class="mt-2 text-xs font-bold text-amber-300">starred clips</p>
    </div>

    <div class="rounded-[28px] border border-white/10 bg-white/[0.04] p-6 shadow-xl shadow-black/10 backdrop-blur-xl">
      <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-500">AI Ready</p>
      <p class="mt-3 text-4xl font-black text-white">ON</p>
      <p class="mt-2 text-xs font-bold text-emerald-300">Sidekiq jobs active</p>
    </div>
  </section>

  <div class="grid gap-8 xl:grid-cols-[1fr_360px]">
    <div class="space-y-8">
      <section>
        <div class="mb-4 flex items-center justify-between">
          <div>
            <h2 class="text-xl font-black text-white">Quick Actions</h2>
            <p class="mt-1 text-sm text-slate-500">Most used ClipMind workflows.</p>
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          <%= link_to quick_add_clips_path, class: "group rounded-[28px] bg-gradient-to-br from-fuchsia-500 via-purple-600 to-violet-700 p-6 text-white shadow-lg shadow-purple-950/30 transition hover:-translate-y-1" do %>
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-white/15 text-xl">＋</div>
            <h3 class="font-black">Quick Add</h3>
            <p class="mt-1 text-sm text-white/75">Save text, code or links</p>
          <% end %>

          <%= link_to ai_search_path, class: "group rounded-[28px] bg-gradient-to-br from-cyan-400 via-blue-500 to-violet-700 p-6 text-white shadow-lg shadow-blue-950/30 transition hover:-translate-y-1" do %>
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-white/15 text-xl">⌕</div>
            <h3 class="font-black">AI Search</h3>
            <p class="mt-1 text-sm text-white/75">Search by context</p>
          <% end %>

          <%= link_to collections_path, class: "group rounded-[28px] bg-gradient-to-br from-emerald-400 via-green-500 to-emerald-700 p-6 text-white shadow-lg shadow-emerald-950/30 transition hover:-translate-y-1" do %>
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-white/15 text-xl">🗂️</div>
            <h3 class="font-black">Collections</h3>
            <p class="mt-1 text-sm text-white/75">Browse smart groups</p>
          <% end %>

          <%= link_to ai_memory_path, class: "group rounded-[28px] bg-gradient-to-br from-pink-500 via-rose-500 to-red-600 p-6 text-white shadow-lg shadow-rose-950/30 transition hover:-translate-y-1" do %>
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-white/15 text-xl">🧠</div>
            <h3 class="font-black">AI Memory</h3>
            <p class="mt-1 text-sm text-white/75">Review saved insights</p>
          <% end %>
        </div>
      </section>

      <section>
        <div class="mb-4 flex items-center justify-between">
          <div>
            <h2 class="text-xl font-black text-white">Recent Clips</h2>
            <p class="mt-1 text-sm text-slate-500">Latest captured clipboard items.</p>
          </div>

          <%= link_to "View all", clips_path, class: "rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm font-bold text-fuchsia-200 transition hover:bg-fuchsia-500/10" %>
        </div>

        <% if @recent_clips.any? %>
          <div class="grid gap-4 md:grid-cols-2">
            <% @recent_clips.each do |clip| %>
              <%= render "shared/compact_clip", clip: clip %>
            <% end %>
          </div>
        <% else %>
          <%= render "shared/empty_state", icon: "📭", title: "No clips found", message: "Copy from the Chrome extension or use Quick Add to start." %>
        <% end %>
      </section>
    </div>

    <aside class="hidden xl:block">
      <%= render "shared/memory_panel" %>
    </aside>
  </div>
</div>
