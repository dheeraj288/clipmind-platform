<div class="grid gap-6 xl:grid-cols-[1fr_340px]">
  <div class="space-y-8">
    <!-- Welcome -->
    <section>
      <h1 class="text-2xl font-bold text-white">
        Good evening, <%= current_user.email.split("@").first.titleize %> 👋
      </h1>
      <p class="mt-2 text-sm text-slate-400">
        Here's what's happening with your clipboard workspace today.
      </p>
    </section>
    <!-- Stats Figma Theme -->
    <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">

      <div class="rounded-xl border border-slate-800 bg-[#111426] p-6">
        <p class="text-sm text-slate-400">Total Clips</p>
        <p class="mt-2 text-3xl font-semibold text-white"><%= @total_clips %></p>
        <p class="mt-1 text-xs font-semibold text-fuchsia-500">
          +<%= @memory_stats[:total] %> today
        </p>
      </div>

      <div class="rounded-xl border border-slate-800 bg-[#111426] p-6">
        <p class="text-sm text-slate-400">Collections</p>
        <p class="mt-2 text-3xl font-semibold text-white"><%= @collections_count %></p>
        <p class="mt-1 text-xs font-semibold text-fuchsia-500">
          active
        </p>
      </div>

      <div class="rounded-xl border border-slate-800 bg-[#111426] p-6">
        <p class="text-sm text-slate-400">AI Prompts</p>
        <p class="mt-2 text-3xl font-semibold text-white">0</p>
        <p class="mt-1 text-xs font-semibold text-fuchsia-500">
          coming soon
        </p>
      </div>

      <div class="rounded-xl border border-slate-800 bg-[#111426] p-6">
        <p class="text-sm text-slate-400">Favorites</p>
        <p class="mt-2 text-3xl font-semibold text-white"><%= @favorite_clips %></p>
        <p class="mt-1 text-xs font-semibold text-fuchsia-500">
          most used
        </p>
      </div>
    </section>
    <!-- Quick Actions -->
    <section>
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-xl font-bold text-white">Quick Actions</h2>
      </div>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">

        <%= link_to quick_add_clips_path,
            class: "rounded-xl bg-gradient-to-br from-fuchsia-500 via-purple-600 to-violet-700 p-6 text-white shadow-lg shadow-purple-950/30 transition hover:-translate-y-1 hover:shadow-purple-900/40" do %>
          <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-xl bg-white/15 text-xl">
            ＋
          </div>
          <h3 class="font-bold">Quick Add</h3>
          <p class="mt-1 text-sm text-white/80">Save text, code or links</p>
        <% end %>

        <%= link_to ai_search_path,
            class: "rounded-xl bg-gradient-to-br from-cyan-400 via-blue-500 to-violet-700 p-6 text-white shadow-lg shadow-blue-950/30 transition hover:-translate-y-1 hover:shadow-blue-900/40" do %>
          <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-xl bg-white/15 text-xl">
            ⌕
          </div>
          <h3 class="font-bold">AI Search</h3>
          <p class="mt-1 text-sm text-white/80">Find anything fast</p>
        <% end %>

        <%= link_to collections_path,
            class: "rounded-xl bg-gradient-to-br from-emerald-400 via-green-500 to-emerald-700 p-6 text-white shadow-lg shadow-emerald-950/30 transition hover:-translate-y-1 hover:shadow-emerald-900/40" do %>
          <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-xl bg-white/15 text-xl">
            🗂️
          </div>
          <h3 class="font-bold">Collections</h3>
          <p class="mt-1 text-sm text-white/80">Browse smart groups</p>
        <% end %>

        <button
          type="button"
          class="rounded-xl bg-gradient-to-br from-pink-500 via-rose-500 to-red-600 p-6 text-left text-white shadow-lg shadow-rose-950/30 transition hover:-translate-y-1 hover:shadow-rose-900/40"
        >
          <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-xl bg-white/15 text-xl">
            ⌘
          </div>
          <h3 class="font-bold">Command Palette</h3>
          <p class="mt-1 text-sm text-white/80">Press Ctrl + K</p>
        </button>
      </div>
    </section>

    <!-- Recent Clips -->
    <section>
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-lg font-bold text-white">Recent Clips</h2>

        <%= link_to "View all",
            clips_path,
            class: "text-sm font-semibold text-fuchsia-400 hover:text-fuchsia-300" %>
      </div>

      <% if @recent_clips.any? %>
        <div class="grid gap-4 md:grid-cols-2">
          <% @recent_clips.each do |clip| %>
            <%= render "shared/compact_clip", clip: clip %>
          <% end %>
        </div>
      <% else %>
        <%= render "shared/empty_state",
            icon: "📭",
            title: "No clips found",
            message: "Chrome extension se copy karoge to clips yaha show honge." %>
      <% end %>
    </section>

  </div>

  <aside class="hidden xl:block">
    <%= render "shared/memory_panel" %>
  </aside>

</div>