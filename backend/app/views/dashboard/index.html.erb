<div class="space-y-8">
  <section class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-white">
        Good evening, Developer 👋
      </h1>

      <p class="mt-2 text-sm text-slate-400">
        Here's what's happening with your clipboard workspace today.
      </p>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <%= render "shared/stat_card", icon: "▣", label: "Total Clips", value: @total_clips %>
    <%= render "shared/stat_card", icon: "▱", label: "Collections", value: @collections_count %>
    <%= render "shared/stat_card", icon: "✧", label: "AI Prompts", value: 0 %>
    <%= render "shared/stat_card", icon: "☆", label: "Favorites", value: @favorite_clips %>
  </section>

  <section>
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-lg font-bold text-white">Quick Actions</h2>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <button class="rounded-2xl bg-gradient-to-br from-fuchsia-600 to-purple-700 p-5 text-left shadow-lg shadow-fuchsia-600/20 transition hover:-translate-y-1">
        <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-white/10 text-xl">
          ▣
        </div>

        <h3 class="font-bold text-white">Save Clipboard</h3>
        <p class="mt-1 text-sm text-fuchsia-100/80">Save current clipboard content</p>
      </button>

      <button class="rounded-2xl bg-gradient-to-br from-cyan-500 to-blue-700 p-5 text-left shadow-lg shadow-cyan-600/20 transition hover:-translate-y-1">
        <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-white/10 text-xl">
          ✧
        </div>

        <h3 class="font-bold text-white">New Prompt</h3>
        <p class="mt-1 text-sm text-cyan-100/80">Create AI prompt template</p>
      </button>

      <button class="rounded-2xl bg-gradient-to-br from-emerald-500 to-green-700 p-5 text-left shadow-lg shadow-emerald-600/20 transition hover:-translate-y-1">
        <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-white/10 text-xl">
          ⧉
        </div>

        <h3 class="font-bold text-white">Quick Paste</h3>
        <p class="mt-1 text-sm text-emerald-100/80">Paste from recent clips</p>
      </button>

      <button class="rounded-2xl bg-gradient-to-br from-pink-500 to-rose-700 p-5 text-left shadow-lg shadow-pink-600/20 transition hover:-translate-y-1">
        <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-white/10 text-xl">
          🧠
        </div>

        <h3 class="font-bold text-white">AI Summarize</h3>
        <p class="mt-1 text-sm text-pink-100/80">Summarize selected text</p>
      </button>
    </div>
  </section>

  <section>
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-lg font-bold text-white">Recent Clips</h2>

      <%= link_to "View all", clips_path, class: "text-sm font-semibold text-fuchsia-400 hover:text-fuchsia-300" %>
    </div>

    <% if @recent_clips.any? %>
      <div class="grid gap-4 xl:grid-cols-2">
        <% @recent_clips.each do |clip| %>
          <%= render "shared/clip_card", clip: clip %>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state",
          icon: "📭",
          title: "No clips found",
          message: "Chrome extension se copy karoge to clips yaha show honge." %>
    <% end %>
  </section>

  <% demo_collections = [
    ["Rails Snippets", "0 items"],
    ["AI Prompts", "0 items"],
    ["API Endpoints", "0 items"],
    ["Terminal Commands", "0 items"]
  ] %>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% demo_collections.each_with_index do |collection, index| %>
      <div class="rounded-2xl bg-gradient-to-br <%= collection_gradients[index] %> p-5">
        <div class="mb-8 flex items-center justify-between">
          <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-white/10 text-xl">
            <%= collection_icons[index] %>
          </div>

          <span class="text-white/70">›</span>
        </div>

        <h3 class="font-bold text-white"><%= collection[0] %></h3>
        <p class="mt-1 text-sm text-white/70"><%= collection[1] %></p>
      </div>
    <% end %>
  </div>

  <section class="rounded-2xl border border-fuchsia-500/20 bg-gradient-to-br from-fuchsia-950/40 to-cyan-950/30 p-6">
    <div class="flex gap-4">
      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-fuchsia-500/20 text-2xl text-fuchsia-300">
        ✧
      </div>

      <div>
        <h2 class="font-bold text-white">AI Insights</h2>

        <p class="mt-2 text-sm leading-6 text-slate-400">
          Based on your recent activity, ClipMind will suggest useful collections and smart groups as your clips grow.
        </p>

        <button class="mt-4 text-sm font-semibold text-fuchsia-400 hover:text-fuchsia-300">
          Create suggested collections →
        </button>
      </div>
    </div>
  </section>
</div>