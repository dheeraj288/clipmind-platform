<div class="space-y-8">
  <section class="relative overflow-hidden rounded-[36px] border border-white/10 bg-white/[0.04] p-6 shadow-2xl shadow-black/20 backdrop-blur-xl lg:p-8">
    <div class="absolute -right-16 -top-16 h-56 w-56 rounded-full bg-amber-400/10 blur-3xl"></div>
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.28em] text-amber-300">Starred clips</p>
        <h1 class="mt-2 bg-gradient-to-r from-white via-amber-100 to-fuchsia-200 bg-clip-text text-3xl font-black tracking-tight text-transparent lg:text-5xl">Favorites</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-400">Your most important snippets, links, commands and saved ideas in one clean view.</p>
      </div>

      <div class="rounded-2xl border border-white/10 bg-white/[0.05] px-5 py-3 text-sm font-black text-slate-200">
        <%= pluralize(@favorites.count, "favorite") %>
      </div>
    </div>
  </section>

  <% if @favorites.any? %>
    <section class="grid gap-5 xl:grid-cols-2">
      <% @favorites.each do |clip| %>
        <%= render "shared/clip_card", clip: clip %>
      <% end %>
    </section>
  <% else %>
    <%= render "shared/empty_state", icon: "⭐", title: "No favorites yet", message: "Click the star on useful clips and they will appear here." %>
  <% end %>
</div>
