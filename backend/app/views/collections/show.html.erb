<div class="space-y-8">
  <section class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <div class="mb-3">
        <%= link_to "← Back to Collections",
            collections_path,
            class: "text-sm font-semibold text-fuchsia-400 hover:text-fuchsia-300" %>
      </div>

      <h1 class="text-2xl font-bold text-white">
        <%= @collection.name %>
      </h1>

      <p class="mt-2 text-sm text-slate-400">
        <%= pluralize(@clips.count, "clip") %> inside this collection.
      </p>
    </div>
  </section>

  <% if @clips.any? %>
    <section class="grid gap-4 xl:grid-cols-2">
      <% @clips.each do |clip| %>
        <%= render "shared/clip_card", clip: clip %>
      <% end %>
    </section>
  <% else %>
    <%= render "shared/empty_state",
        icon: "📭",
        title: "No clips in this collection",
        message: "Abhi is collection me koi clip assign nahi hai." %>
  <% end %>
</div>