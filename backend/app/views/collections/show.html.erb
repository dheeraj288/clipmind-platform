<div class="space-y-8">
  <section class="relative overflow-hidden rounded-[36px] border border-white/10 bg-white/[0.04] p-6 shadow-2xl shadow-black/20 backdrop-blur-xl lg:p-8">
    <div class="absolute -right-16 -top-16 h-56 w-56 rounded-full bg-fuchsia-500/10 blur-3xl"></div>

    <%= link_to "← Back to Collections", collections_path, class: "inline-flex rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm font-bold text-fuchsia-200 transition hover:bg-fuchsia-500/10" %>

    <div class="mt-6 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.28em] text-fuchsia-300">Collection</p>
        <h1 class="mt-2 bg-gradient-to-r from-white via-fuchsia-100 to-cyan-200 bg-clip-text text-3xl font-black tracking-tight text-transparent lg:text-5xl"><%= @collection.name %></h1>
        <p class="mt-3 text-sm leading-6 text-slate-400"><%= pluralize(@clips.count, "clip") %> inside this focused workspace.</p>
      </div>
    </div>
  </section>

  <% if @clips.any? %>
    <section class="grid gap-5 xl:grid-cols-2">
      <% @clips.each do |clip| %>
        <%= render "shared/clip_card", clip: clip %>
      <% end %>
    </section>
  <% else %>
    <%= render "shared/empty_state", icon: "📭", title: "No clips in this collection", message: "Assign clips to this collection from any clip card." %>
  <% end %>
</div>
