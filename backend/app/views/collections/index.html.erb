<div class="space-y-8">
  <section class="relative overflow-hidden rounded-[36px] border border-white/10 bg-white/[0.04] p-6 shadow-2xl shadow-black/20 backdrop-blur-xl lg:p-8">
    <div class="absolute -right-16 -top-16 h-56 w-56 rounded-full bg-emerald-400/10 blur-3xl"></div>
    <p class="text-xs font-black uppercase tracking-[0.28em] text-emerald-300">Smart workspaces</p>
    <div class="mt-3 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <h1 class="bg-gradient-to-r from-white via-emerald-100 to-cyan-200 bg-clip-text text-3xl font-black tracking-tight text-transparent lg:text-5xl">Collections</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-400">Organize clips into focused spaces for code, links, commands, notes and research.</p>
      </div>

      <div class="rounded-2xl border border-white/10 bg-white/[0.05] px-5 py-3 text-sm font-black text-slate-200">
        <%= pluralize(@collections.to_a.size, "collection") %>
      </div>
    </div>
  </section>

  <%= render "shared/collection_form", collection: @collection %>

  <%= render "collections/list", collections: @collections %>
</div>
