<div class="space-y-8">
  <section class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-white">Collections</h1>

      <p class="mt-2 text-sm text-slate-400">
        Organize your clips into smart groups and reusable workspaces.
      </p>
    </div>
  </section>

  <%= render "shared/collection_form", collection: @collection %>

  <% if @collections.any? %>
    <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <% @collections.each_with_index do |collection, index| %>
        <%= render "shared/collection_card",
            collection: collection,
            index: index %>
      <% end %>
    </section>
  <% else %>
    <%= render "shared/empty_state",
        icon: "📚",
        title: "No collections yet",
        message: "Collection create karoge to clips ko groups me organize kar paoge." %>
  <% end %>
</div>