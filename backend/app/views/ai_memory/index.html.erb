<style>
  .ai-memory-code pre[class*="language-"] {
    background: transparent !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  .ai-memory-code code[class*="language-"] {
    background: transparent !important;
    text-shadow: none !important;
    font-family: "JetBrains Mono", monospace !important;
    font-size: 13px !important;
    line-height: 1.8rem !important;
    white-space: pre !important;
  }

  .ai-memory-code .token.operator {
    background: transparent !important;
  }
</style>

<div class="mx-auto max-w-6xl">
  <div class="mb-8 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="text-xs font-black uppercase tracking-[0.3em] text-emerald-300">ClipMind AI</p>
      <h1 class="mt-2 text-3xl font-black text-white">AI Memory</h1>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-400">
        Saved AI summaries and important clipboard memories for your second brain.
      </p>
    </div>

    <div class="rounded-3xl border border-emerald-400/20 bg-emerald-400/10 px-5 py-4">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-emerald-300">Saved Memories</p>
      <p class="mt-1 text-2xl font-black text-white"><%= @memories.count %></p>
    </div>
  </div>

  <div class="mb-10 rounded-3xl border border-white/10 bg-white/[0.03] p-4">
    <%= form_with url: ai_memory_path, method: :get, local: true, class: "flex flex-col gap-3 lg:flex-row" do %>
      <%= text_field_tag :q, @query,
          placeholder: "Search saved AI memories...",
          class: "min-h-12 flex-1 rounded-2xl border border-white/10 bg-slate-900 px-4 text-sm text-white outline-none placeholder:text-slate-500 focus:border-emerald-400/40" %>

      <%= select_tag :filter,
          options_for_select([["All", "all"], ["Code", "code"], ["Links", "link"], ["Text", "text"]], @filter),
          class: "min-h-12 rounded-2xl border border-white/10 bg-slate-900 px-4 text-sm font-bold text-slate-200 outline-none focus:border-emerald-400/40" %>

      <%= submit_tag "Search",
          class: "min-h-12 rounded-2xl bg-emerald-500 px-6 text-sm font-black text-slate-950 transition hover:bg-emerald-400" %>

      <%= link_to "Reset", ai_memory_path,
          class: "inline-flex min-h-12 items-center justify-center rounded-2xl border border-white/10 bg-white/5 px-6 text-sm font-bold text-slate-300 transition hover:bg-white/10 hover:text-white" %>
    <% end %>
  </div>

  <% if @timeline.any? %>
    <% @timeline.each do |label, clips| %>
      <div class="mb-12">
        <div class="mb-8">
          <span class="rounded-full border border-emerald-500/20 bg-emerald-500/10 px-4 py-2 text-sm font-bold text-emerald-300">
            <%= label %>
          </span>
        </div>

        <div class="relative ml-4 border-l border-white/10">
          <% clips.each do |clip| %>
            <div class="relative mb-6 pl-8">
              <div class="absolute -left-[6px] top-10 h-3 w-3 rounded-full bg-emerald-400 shadow-lg shadow-emerald-500/40"></div>

              <div class="overflow-hidden rounded-3xl border border-white/10 bg-[#0B1020] transition hover:border-emerald-500/30">
                <div class="border-b border-white/10 bg-gradient-to-r from-emerald-500/10 via-cyan-500/10 to-violet-500/10 p-5">
                  <div class="flex items-start justify-between gap-5">
                    <div class="flex-1">
                      <div class="mb-3 flex flex-wrap items-center gap-2">
                        <span class="rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-[10px] font-black uppercase text-emerald-200">
                          ⭐ AI Memory
                        </span>

                        <% if clip.clip_type.present? %>
                          <span class="rounded-full bg-indigo-500/10 px-3 py-1 text-[10px] font-bold uppercase text-indigo-200">
                            <%= clip.clip_type %>
                          </span>
                        <% end %>

                        <% if clip.language.present? %>
                          <span class="rounded-full bg-fuchsia-500/10 px-3 py-1 text-[10px] font-bold uppercase text-fuchsia-200">
                            <%= clip.language %>
                          </span>
                        <% end %>
                      </div>

                      <h3 class="text-lg font-black text-white">
                        <%= clean_clip_title(clip) %>
                      </h3>

                      <p class="mt-2 text-xs text-slate-500">
                        Saved <%= time_ago_in_words(clip.ai_memory_saved_at || clip.updated_at) %> ago
                      </p>
                    </div>

                    <%= link_to "Open Clip", clips_path(anchor: dom_id(clip)),
                        class: "shrink-0 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-bold text-slate-300 transition hover:bg-white/10 hover:text-white" %>
                  </div>
                </div>

                <div class="p-5">
                  <div class="mb-4 flex items-center justify-between">
                    <div class="flex items-center gap-2">
                      <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
                      <span class="text-xs font-black uppercase tracking-[0.2em] text-emerald-300">AI Analysis</span>
                    </div>

                    <button
                      type="button"
                      data-controller="copy-summary"
                      data-copy-summary-text-value="<%= h(clip.ai_summary) %>"
                      data-action="click->copy-summary#copy"
                      class="rounded-full border border-cyan-400/20 bg-cyan-400/10 px-3 py-2 text-[11px] font-bold text-cyan-200 hover:bg-cyan-400/20">
                      📋 Copy
                    </button>
                  </div>

                  <div class="rounded-2xl border border-white/10 bg-black/30 p-5 text-left">
                    <div class="whitespace-pre-wrap text-sm leading-7 text-slate-200"><%= clip.ai_summary %></div>
                  </div>

                  <details class="group mt-4 overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03]">
                    <summary class="flex cursor-pointer list-none items-center justify-between px-4 py-3 text-sm font-bold text-slate-300 transition hover:bg-white/[0.04] hover:text-white">
                      <span>📄 View original clip</span>
                      <span class="text-xs text-slate-500 transition group-open:rotate-180">⌄</span>
                    </summary>

                    <div class="border-t border-white/10 bg-[#070A14]">
                      <div class="flex items-center gap-2 border-b border-white/10 px-4 py-3">
                        <span class="h-3 w-3 rounded-full bg-red-500"></span>
                        <span class="h-3 w-3 rounded-full bg-yellow-400"></span>
                        <span class="h-3 w-3 rounded-full bg-green-400"></span>

                        <span class="ml-3 truncate text-xs font-bold text-slate-400">
                          <%= clean_clip_title(clip) %>
                        </span>
                      </div>

                      <div class="ai-memory-code px-6 py-5">
                        <pre class="max-h-[420px] overflow-auto text-left"><code class="language-<%= (clip.language.presence || 'ruby').downcase %>"><%= clip.content.to_s.strip %></code></pre>
                      </div>
                    </div>
                  </details>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="rounded-3xl border border-dashed border-white/10 bg-white/[0.03] px-6 py-16 text-center">
      <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-3xl bg-emerald-400/10 text-3xl">🧠</div>

      <h2 class="mt-5 text-xl font-black text-white">No saved AI memories yet</h2>

      <p class="mx-auto mt-2 max-w-md text-sm leading-6 text-slate-400">
        Go to Clips, generate an AI summary, then click ⭐ Save Memory.
      </p>

      <%= link_to "Go to Clips", clips_path,
          class: "mt-6 inline-flex rounded-2xl bg-emerald-500 px-5 py-3 text-sm font-black text-slate-950 transition hover:bg-emerald-400" %>
    </div>
  <% end %>
</div>