<div class="mx-auto max-w-5xl">

  <div class="mb-10">
    <h1 class="text-3xl font-bold text-white">
      AI Memory Timeline
    </h1>

    <p class="mt-2 text-sm text-slate-400">
      Your clipboard activity organized like a memory stream
    </p>
  </div>


  <% @timeline.each do |label, clips| %>

    <div class="mb-12">

      <div class="mb-8">
        <span class="rounded-full border border-fuchsia-500/20 bg-fuchsia-500/10 px-4 py-2 text-sm font-semibold text-fuchsia-300">
          <%= label %>
        </span>
      </div>


      <div class="relative ml-4 border-l border-white/10">

        <% clips.each do |clip| %>

         <div class="relative mb-6 pl-8">

              <!-- Dot -->
              <div class="absolute -left-[6px] top-10 h-3 w-3 rounded-full bg-fuchsia-500 shadow-lg shadow-fuchsia-500/40"></div>

              <div class="rounded-2xl border border-white/10 bg-[#0B1020] p-5 transition hover:border-fuchsia-500/30">

                <div class="flex items-start justify-between gap-5">

                  <div class="flex-1">

                    <div class="mb-3 flex items-center gap-2">

                      <span class="rounded-full bg-indigo-500/10 px-2.5 py-1 text-[10px] font-bold uppercase text-indigo-200">
                        <%= clip.clip_type %>
                      </span>

                      <% if clip.language.present? %>
                        <span class="rounded-full bg-fuchsia-500/10 px-2.5 py-1 text-[10px] font-bold uppercase text-fuchsia-200">
                          <%= clip.language %>
                        </span>
                      <% end %>

                    </div>

                    <h3 class="font-bold text-white">
                      <%= clean_clip_title(clip) %>
                    </h3>

                    <p class="mt-3 line-clamp-2 text-sm text-slate-400">
                      <%= truncate(clip.content, length: 120) %>
                    </p>

                  </div>

                  <div class="shrink-0 text-right">

                    <p class="mb-4 text-xs text-slate-500">
                      <%= time_ago_in_words(clip.created_at) %> ago
                    </p>

                    <%= link_to "View",
                        clips_path(anchor: dom_id(clip)),
                        class: "rounded-lg bg-fuchsia-500/10 px-3 py-2 text-xs font-semibold text-fuchsia-300 hover:bg-fuchsia-500/20" %>

                  </div>

                </div>

              </div>

            </div>
        <% end %>

      </div>

    </div>

  <% end %>

</div>