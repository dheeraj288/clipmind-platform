<div class="space-y-8">
  <section class="relative overflow-hidden rounded-[36px] border border-white/10 bg-white/[0.04] p-6 shadow-2xl shadow-black/20 backdrop-blur-xl lg:p-8">
    <div class="absolute -right-16 -top-16 h-60 w-60 rounded-full bg-fuchsia-500/15 blur-3xl"></div>

    <div class="relative flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
      <div class="flex items-center gap-5">
        <div class="flex h-20 w-20 items-center justify-center rounded-[28px] bg-gradient-to-br from-fuchsia-500 via-violet-600 to-cyan-400 text-3xl font-black text-white shadow-xl shadow-fuchsia-950/40">
          <%= current_user.name.to_s.first&.upcase || current_user.email.first.upcase %>
        </div>

        <div>
          <p class="text-xs font-black uppercase tracking-[0.25em] text-fuchsia-300">Profile</p>
          <h1 class="mt-2 text-3xl font-black text-white"><%= current_user.name.presence || "ClipMind User" %></h1>
          <p class="mt-2 text-sm text-slate-400"><%= current_user.email %></p>
        </div>
      </div>

      <div class="rounded-2xl border border-white/10 bg-white/[0.05] px-5 py-3 text-sm font-black text-slate-200">Pro Workspace</div>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% [["Total Clips", @total_clips, "📋"], ["Collections", @collections_count, "🗂️"], ["Favorites", @favorites_count, "⭐"], ["Total Copies", @copies_count, "⚡"]].each do |label, value, icon| %>
      <div class="rounded-[28px] border border-white/10 bg-white/[0.04] p-6 shadow-xl shadow-black/10 backdrop-blur-xl">
        <div class="text-2xl"><%= icon %></div>
        <p class="mt-4 text-xs font-black uppercase tracking-[0.2em] text-slate-500"><%= label %></p>
        <h3 class="mt-2 text-3xl font-black text-white"><%= value %></h3>
      </div>
    <% end %>
  </section>

  <section class="rounded-[32px] border border-white/10 bg-white/[0.04] p-6 shadow-2xl shadow-black/10 backdrop-blur-xl">
    <div class="mb-5 flex items-center justify-between">
      <div>
        <h2 class="text-xl font-black text-white">Recent Activity</h2>
        <p class="mt-1 text-sm text-slate-500">Latest clips saved in your workspace.</p>
      </div>
    </div>

    <div class="space-y-3">
      <% if @recent_clips.any? %>
        <% @recent_clips.each do |clip| %>
          <div class="rounded-2xl border border-white/10 bg-slate-950/50 p-4 transition hover:bg-white/[0.04]">
            <div class="flex items-center justify-between gap-4">
              <div class="min-w-0">
                <p class="truncate font-bold text-white"><%= clip.title.presence || clip.clip_type.to_s.titleize %></p>
                <p class="mt-1 text-xs text-slate-500"><%= time_ago_in_words(clip.created_at) %> ago</p>
              </div>

              <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs font-bold text-slate-400"><%= clip.clip_type %></span>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="text-sm text-slate-500">No recent activity yet.</p>
      <% end %>
    </div>
  </section>
</div>
