<div class="space-y-8">
  <section>
    <h1 class="text-2xl font-bold text-white">Profile</h1>

    <p class="mt-2 text-sm text-slate-400">
      Your ClipMind profile and activity.
    </p>
  </section>

  <section class="rounded-3xl border border-fuchsia-500/20 bg-gradient-to-br from-fuchsia-950/70 to-cyan-950/40 p-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
      <div class="flex items-center gap-5">
        <div class="flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-fuchsia-500 to-cyan-400 text-2xl font-bold text-white">
          <%= current_user.name.to_s.first&.upcase || current_user.email.first.upcase %>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-white">
            <%= current_user.name.presence || "ClipMind User" %>
          </h2>

          <p class="mt-1 text-sm text-slate-300">
            Pro Member
          </p>

          <p class="mt-3 text-sm text-slate-400">
            <%= current_user.email %>
          </p>
        </div>
      </div>

      <button class="rounded-xl bg-slate-800 px-4 py-2 text-sm font-semibold text-slate-200 hover:bg-slate-700">
        Edit Profile
      </button>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-2xl border border-slate-800 bg-slate-900 p-5">
      <p class="text-sm text-slate-400">Total Clips</p>
      <h3 class="mt-3 text-3xl font-bold text-white"><%= @total_clips %></h3>
    </div>

    <div class="rounded-2xl border border-slate-800 bg-slate-900 p-5">
      <p class="text-sm text-slate-400">Collections</p>
      <h3 class="mt-3 text-3xl font-bold text-white"><%= @collections_count %></h3>
    </div>

    <div class="rounded-2xl border border-slate-800 bg-slate-900 p-5">
      <p class="text-sm text-slate-400">Favorites</p>
      <h3 class="mt-3 text-3xl font-bold text-white"><%= @favorites_count %></h3>
    </div>

    <div class="rounded-2xl border border-slate-800 bg-slate-900 p-5">
      <p class="text-sm text-slate-400">Total Copies</p>
      <h3 class="mt-3 text-3xl font-bold text-white"><%= @copies_count %></h3>
    </div>
  </section>

  <section class="rounded-2xl border border-slate-800 bg-slate-900 p-6">
    <h2 class="text-lg font-bold text-white">Recent Activity</h2>

    <div class="mt-5 space-y-3">
      <% if @recent_clips.any? %>
        <% @recent_clips.each do |clip| %>
          <div class="rounded-xl border border-slate-800 bg-slate-950 p-4">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="font-semibold text-white">
                  <%= clip.title.presence || clip.clip_type.to_s.titleize %>
                </p>

                <p class="mt-1 text-xs text-slate-500">
                  <%= time_ago_in_words(clip.created_at) %> ago
                </p>
              </div>

              <span class="rounded-full border border-slate-700 px-3 py-1 text-xs text-slate-400">
                <%= clip.clip_type %>
              </span>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="text-sm text-slate-500">No recent activity yet.</p>
      <% end %>
    </div>
  </section>
</div>