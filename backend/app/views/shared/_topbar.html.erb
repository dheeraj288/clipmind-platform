<header class="h-[87px] border-b border-white/10 px-6 flex items-center">
  <div class="mx-auto flex w-full max-w-[1500px] items-center gap-4">
    <%= form_with url: ai_search_path,
        method: :get,
        class: "hidden min-h-12 flex-1 items-center rounded-2xl border border-white/10 bg-white/[0.04] px-4 shadow-lg shadow-black/10 transition focus-within:border-fuchsia-400/40 lg:flex",
        data: { turbo: false } do %>
      <span class="mr-3 text-slate-500">⌕</span>
      <%= text_field_tag :q,
          params[:q],
          placeholder: "Search clips, summaries, tags, links...",
          class: "w-full bg-transparent text-sm font-medium text-slate-200 outline-none placeholder:text-slate-500" %>
      <kbd class="rounded-lg border border-white/10 bg-black/20 px-2 py-1 text-[10px] font-bold text-slate-500">Enter</kbd>
    <% end %>

    <div class="ml-auto flex items-center gap-2 sm:gap-3">
      <%= link_to quick_add_clips_path,
          class: "inline-flex min-h-11 items-center gap-2 rounded-2xl bg-gradient-to-r from-fuchsia-600 to-indigo-600 px-4 py-2 text-sm font-black text-white shadow-lg shadow-fuchsia-950/30 transition hover:-translate-y-0.5 hover:shadow-fuchsia-900/40" do %>
        <span>＋</span><span class="hidden sm:inline">Quick Add</span>
      <% end %>

      <%= link_to "/sidekiq",
          class: "hidden min-h-11 items-center rounded-2xl border border-white/10 bg-white/[0.04] px-4 text-xs font-bold text-slate-300 transition hover:bg-white/[0.08] hover:text-white xl:inline-flex" do %>
        Jobs
      <% end %>

      <%= button_to "Logout",
          logout_path,
          method: :delete,
          class: "min-h-11 rounded-2xl border border-white/10 bg-white/[0.04] px-4 text-xs font-bold text-slate-300 transition hover:border-red-400/30 hover:bg-red-500/10 hover:text-red-200" %>
    </div>
  </div>
</header>
