<header class="sticky top-0 z-30 border-b border-slate-800 bg-slate-950/95 px-6 py-3 backdrop-blur">
  <div class="flex items-center justify-between gap-4">
    <div class="hidden w-full max-w-xl items-center rounded-xl border border-slate-800 bg-slate-900 px-4 py-2 lg:flex">
      <span class="mr-3 text-slate-500">⌕</span>

      <input
        type="text"
        placeholder="Search everything..."
        class="w-full bg-transparent text-sm text-slate-200 outline-none placeholder:text-slate-500"
      >

      <kbd class="rounded-md bg-slate-800 px-2 py-1 text-xs text-slate-500">⌘ K</kbd>
    </div>

    <div class="ml-auto flex items-center gap-3">
      <button class="relative rounded-xl p-2 text-slate-300 hover:bg-slate-900 hover:text-white">
        🔔
        <span class="absolute right-1 top-1 h-2 w-2 rounded-full bg-fuchsia-500"></span>
      </button>

      <%= link_to "+ Quick Add",
          quick_add_path,
          class: "rounded-xl bg-fuchsia-600 px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-fuchsia-600/30 hover:bg-fuchsia-500" %>

      <%= button_to "Logout",
          logout_path,
          method: :delete,
          class: "rounded-xl border border-slate-700 px-3 py-2 text-xs font-semibold text-slate-300 hover:bg-slate-900 hover:text-white" %>

      <div class="flex h-9 w-9 items-center justify-center rounded-full bg-gradient-to-br from-fuchsia-500 to-cyan-400 text-sm font-bold text-white">
        JD
      </div>
    </div>
  </div>
</header>