<%= link_to collection_path(collection),
    class: "group relative block overflow-hidden rounded-[30px] border border-white/10 bg-white/[0.04] p-6 shadow-xl shadow-black/10 backdrop-blur-xl transition duration-300 hover:-translate-y-1 hover:border-fuchsia-400/25 hover:bg-white/[0.06]" do %>

  <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r <%= collection_gradients[index % collection_gradients.length] %>"></div>
  <div class="absolute -right-10 -top-10 h-32 w-32 rounded-full bg-fuchsia-500/10 blur-3xl transition group-hover:bg-cyan-400/10"></div>

  <div class="relative mb-8 flex items-center justify-between">
    <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br <%= collection_gradients[index % collection_gradients.length] %> text-2xl text-white shadow-lg shadow-black/20">
      <%= collection_icons[index % collection_icons.length] %>
    </div>

    <span class="flex h-9 w-9 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-lg text-white/70 transition group-hover:translate-x-1 group-hover:bg-white/[0.08]">
      ›
    </span>
  </div>

  <h3 class="relative line-clamp-1 text-lg font-black tracking-tight text-white">
    <%= collection.name %>
  </h3>

  <div class="relative mt-4 flex items-center justify-between gap-3 border-t border-white/10 pt-4">
    <p class="rounded-full bg-white/[0.05] px-3 py-1.5 text-xs font-bold text-slate-300">
      <%= pluralize(collection.clips_count, "item") %>
    </p>

    <p class="text-xs font-semibold text-slate-500">
      <%= time_ago_in_words(collection.created_at) %> ago
    </p>
  </div>
<% end %>
