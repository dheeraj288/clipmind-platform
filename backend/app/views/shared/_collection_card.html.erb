<%= link_to collection_path(collection),
    class: "group block rounded-2xl bg-gradient-to-br #{collection_gradients[index % collection_gradients.length]} p-6 shadow-lg transition duration-300 hover:-translate-y-1" do %>

  <div class="mb-8 flex items-center justify-between">
    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-white/15 text-2xl backdrop-blur">
      <%= collection_icons[index % collection_icons.length] %>
    </div>

    <span class="text-xl text-white/70 transition group-hover:translate-x-1">
      ›
    </span>
  </div>

  <h3 class="text-lg font-bold text-white">
    <%= collection.name %>
  </h3>

  <p class="mt-1 text-sm text-white/80">
    <%= pluralize(collection.clips_count, "item") %>
  </p>

  <p class="mt-4 text-xs text-white/60">
    <%= time_ago_in_words(collection.created_at) %> ago
  </p>
<% end %>