<div class="rounded-2xl border border-slate-800 bg-slate-900 p-5">

  <div class="mb-4 flex items-start justify-between">

    <div>
      <h3 class="font-bold text-white">
        <%= clip.title.presence || "Untitled Clip" %>
      </h3>

      <p class="mt-1 text-xs text-slate-500">
        <%= time_ago_in_words(clip.created_at) %> ago
      </p>
    </div>

    <div class="rounded-full bg-fuchsia-500/20 px-3 py-1 text-xs font-semibold text-fuchsia-300">
      ★ Favorite
    </div>

  </div>

  <div class="rounded-xl bg-slate-950 p-4">
    <pre class="overflow-hidden text-sm text-slate-300"><%= truncate(clip.content, length: 180) %></pre>
  </div>

</div>