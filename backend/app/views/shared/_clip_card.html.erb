<div id="<%= dom_id(clip) %>" class="group rounded-3xl border border-slate-800 bg-slate-900/95 p-5 transition hover:border-fuchsia-500/30 hover:shadow-xl hover:shadow-fuchsia-950/20">

  <div class="mb-3 flex justify-end">

    <input
      type="checkbox"
      value="<%= clip.id %>"
      data-bulk-actions-target="checkbox"
      data-action="change->bulk-actions#update"
      class="h-4 w-4 rounded border-slate-700 bg-slate-950 accent-fuchsia-600"
    />

  </div>

  <div class="mb-5 flex items-start justify-between gap-5">    <div class="min-w-0 flex-1">
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <span class="rounded-full border border-indigo-500/20 bg-indigo-500/10 px-3 py-1 text-xs font-bold uppercase tracking-wide text-indigo-300">
          <%= clip.clip_type.to_s.presence || "CLIP" %>
        </span>

        <% if clip.language.present? %>
          <span class="rounded-full border border-fuchsia-500/20 bg-fuchsia-500/10 px-3 py-1 text-xs font-semibold text-fuchsia-300">
            <%= clip.language %>
          </span>
        <% end %>

        <% if clip.is_pinned? %>
          <span class="rounded-full border border-cyan-500/20 bg-cyan-500/10 px-3 py-1 text-xs font-semibold text-cyan-300">
            📌 Pinned
          </span>
        <% end %>

        <span class="rounded-full border border-slate-700 bg-slate-950 px-3 py-1 text-xs text-slate-400">
          <%= time_ago_in_words(clip.created_at) %> ago
        </span>
      </div>

     

      <% if clip.page_title.present? || clip.source_url.present? %>
        <%= link_to clip.source_url.presence || "#",
            target: "_blank",
            rel: "noopener",
            class: "mt-3 flex max-w-md items-center gap-3 rounded-xl bg-slate-950/80 px-3 py-2 hover:bg-slate-800" do %>

            <% if clip_favicon_url(clip).present? %>
              <%= image_tag clip_favicon_url(clip),
                  class: "h-6 w-6 rounded-md object-cover",
                  alt: "" %>
            <% else %>
            <div class="flex h-6 w-6 items-center justify-center rounded-md bg-slate-800 text-xs text-slate-400">
              🌐
            </div>
          <% end %>

          <div class="min-w-0">
            <p class="truncate text-sm font-semibold text-white">
              <%= clip.page_title.presence || clean_clip_title(clip) %>
            </p>

            <% if clip.source_url.present? %>
              <p class="truncate text-xs text-slate-500">
                <%= clip_domain(clip) %>
              </p>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <% if ["code", "json", "command"].include?(clip.clip_type.to_s) %>
    <div data-controller="code-preview" class="code-window overflow-hidden rounded-2xl border border-slate-800 bg-slate-950">
      <div class="flex items-center justify-between border-b border-slate-800 bg-slate-950 px-4 py-3">
        <div class="flex items-center gap-2">
          <span class="h-3 w-3 rounded-full bg-red-500"></span>
          <span class="h-3 w-3 rounded-full bg-yellow-500"></span>
          <span class="h-3 w-3 rounded-full bg-green-500"></span>

          <span class="ml-3 text-xs font-bold uppercase tracking-wide text-slate-400">
            <%= clip.language.presence || clip.clip_type.to_s %>
          </span>
        </div>

        <button
          type="button"
          data-action="click->code-preview#toggle"
          data-code-preview-target="button"
          class="rounded-full border border-slate-700 px-3 py-1 text-xs font-semibold text-slate-300 hover:bg-slate-800 hover:text-white">
          Show More
        </button>
      </div>

      <pre data-code-preview-target="content" class="max-h-72 transition-all duration-300"><code class="language-<%= (clip.language.presence || 'ruby').downcase %>"><%= h clip.content.to_s.strip %></code></pre>
    </div>
  <% else %>
    <div class="rounded-2xl border border-slate-800 bg-slate-950 p-4">
      <p class="line-clamp-6 whitespace-pre-wrap text-sm leading-6 text-slate-300">
        <%= clip.content %>
      </p>
    </div>
  <% end %>

  <div class="mt-5 border-t border-slate-800 pt-4">
    <div class="flex flex-col gap-3 xl:flex-row xl:items-center xl:justify-between">
      <div class="flex flex-wrap items-center gap-2">
        <div data-controller="clips" data-clips-content-value="<%= clip.content %>">
          <%= button_to increment_copy_clip_path(clip),
              method: :patch,
              form: {
                data: {
                  action: "submit->clips#copy"
                }
              },
              class: "inline-flex items-center gap-2 rounded-xl border border-indigo-500/30 bg-indigo-500/10 px-4 py-2 text-xs font-semibold text-indigo-200 hover:bg-indigo-500 hover:text-white" do %>
            <span>📋</span>
            <span>Copy</span>
          <% end %>
        </div>

        <span class="inline-flex items-center gap-2 rounded-xl border border-slate-800 bg-slate-950 px-4 py-2 text-xs text-slate-400">
          <span>⚡</span>
          <span><%= clip.copy_count || 0 %> copies</span>
        </span>

        <% if clip.collection.present? %>
          <span class="inline-flex items-center gap-2 rounded-xl border border-fuchsia-500/20 bg-fuchsia-500/10 px-4 py-2 text-xs text-fuchsia-200">
            <span>🗂️</span>
            <span><%= clip.collection.name %></span>
          </span>
        <% end %>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <%= button_to toggle_favorite_clip_path(clip),
            method: :patch,
            class: "inline-flex items-center gap-2 rounded-xl border px-4 py-2 text-xs font-semibold transition #{clip.is_favorite? ? 'border-fuchsia-500/30 bg-fuchsia-500/10 text-fuchsia-200' : 'border-slate-700 bg-slate-950 text-slate-400 hover:bg-slate-800 hover:text-white'}" do %>
          <span><%= clip.is_favorite? ? "★" : "☆" %></span>
          <span><%= clip.is_favorite? ? "Favorited" : "Favorite" %></span>
        <% end %>

        <%= button_to toggle_pin_clip_path(clip),
            method: :patch,
            class: "inline-flex items-center gap-2 rounded-xl border px-4 py-2 text-xs font-semibold transition #{clip.is_pinned? ? 'border-cyan-500/30 bg-cyan-500/10 text-cyan-200' : 'border-slate-700 bg-slate-950 text-slate-400 hover:bg-slate-800 hover:text-white'}" do %>
          <span><%= clip.is_pinned? ? "📌" : "📍" %></span>
          <span><%= clip.is_pinned? ? "Pinned" : "Pin" %></span>
        <% end %>

        <%= button_to clip_path(clip),
            method: :delete,
            form: {
              data: {
                turbo_confirm: "Are you sure you want to delete this clip?"
              }
            },
            class: "inline-flex items-center gap-2 rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-2 text-xs font-semibold text-red-300 hover:bg-red-500 hover:text-white" do %>
          <span>🗑️</span>
          <span>Delete</span>
        <% end %>
      </div>
    </div>

    <% available_collections = local_assigns[:collections] || @collections %>

    <% if available_collections.present? %>
      <div class="mt-4">
        <%= form_with model: clip,
            url: update_collection_clip_path(clip),
            method: :patch,
            class: "grid gap-3 sm:grid-cols-[1fr_110px]" do |form| %>

          <%= form.select :collection_id,
              options_from_collection_for_select(available_collections, :id, :name, clip.collection_id),
              { include_blank: "No Collection" },
              class: "rounded-xl border border-slate-700 bg-slate-950 px-3 py-2 text-xs text-white outline-none focus:border-fuchsia-500" %>

          <%= form.submit "Save",
              class: "cursor-pointer rounded-xl bg-slate-800 px-3 py-2 text-xs font-semibold text-slate-200 hover:bg-fuchsia-600 hover:text-white" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>