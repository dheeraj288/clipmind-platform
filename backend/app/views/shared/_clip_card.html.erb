<div
  id="<%= dom_id(clip) %>"
  class="group relative overflow-hidden rounded-[28px] border border-white/10 bg-gradient-to-b from-slate-900 to-slate-950 p-5 shadow-[0_0_0_1px_rgba(255,255,255,0.02)] transition-all duration-300 hover:-translate-y-1 hover:border-fuchsia-500/30 hover:shadow-2xl hover:shadow-fuchsia-950/30"
>

  <!-- Glow -->
  <div class="pointer-events-none absolute inset-0 opacity-0 transition duration-500 group-hover:opacity-100">
    <div class="absolute -top-24 right-0 h-48 w-48 rounded-full bg-fuchsia-500/10 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 h-32 w-32 rounded-full bg-indigo-500/10 blur-3xl"></div>
  </div>

  <!-- Checkbox -->
  <div class="relative z-10 mb-4 flex justify-end">
    <input
      type="checkbox"
      value="<%= clip.id %>"
      data-bulk-actions-target="checkbox"
      data-action="change->bulk-actions#update"
      class="h-4 w-4 rounded border-slate-700 bg-slate-950 accent-fuchsia-600"
    />
  </div>

  <!-- Header -->
  <div class="relative z-10 mb-5">

    <!-- TOP ROW -->
    <div class="flex items-start justify-between gap-4">

      <div class="min-w-0 flex-1">

        <!-- Tags -->
        <div class="flex flex-wrap items-center gap-2">

          <!-- Type -->
          <span class="rounded-full border border-indigo-400/20 bg-indigo-500/10 px-2.5 py-1 text-[10px] font-bold uppercase tracking-[0.16em] text-indigo-200 backdrop-blur-xl">
            <%= clip.clip_type.to_s.presence || "CLIP" %>
          </span>

          <!-- Language -->
          <% if clip.language.present? && !["code", "json", "command"].include?(clip.clip_type.to_s) %>
            <span class="rounded-full border border-fuchsia-400/20 bg-fuchsia-500/10 px-2.5 py-1 text-[10px] font-semibold text-fuchsia-200 backdrop-blur-xl">
              <%= clip.language %>
            </span>
          <% end %>

          <!-- Pinned -->
          <% if clip.is_pinned? %>
            <span class="rounded-full border border-cyan-400/20 bg-cyan-500/10 px-2.5 py-1 text-[10px] font-semibold text-cyan-100 backdrop-blur-xl">
              📌
            </span>
          <% end %>

          <!-- Time -->
          <span class="text-[11px] text-slate-500">
            <%= time_ago_in_words(clip.created_at) %> ago
          </span>

        </div>

        <!-- Title -->
        <% unless ["code", "json", "command"].include?(clip.clip_type.to_s) %>
          <h2 class="mt-3 line-clamp-1 text-lg font-bold tracking-tight text-white transition group-hover:text-fuchsia-100">
            <%= clean_clip_title(clip) %>
          </h2>
        <% end %>

        <!-- Description -->
        <% if clip.page_description.present? %>
          <p class="mt-3 line-clamp-2 text-sm leading-6 text-slate-400">
            <%= clip.page_description %>
          </p>
        <% end %>

        <!-- Source -->
        <% if clip.page_title.present? || clip.source_url.present? %>

          <%= link_to clip.source_url.presence || "#",
              target: "_blank",
              rel: "noopener",
              class: "mt-4 flex max-w-md items-center gap-3 rounded-2xl border border-white/5 bg-black/20 px-3 py-3 backdrop-blur-xl transition hover:border-fuchsia-500/20 hover:bg-slate-900/80" do %>

            <% if clip_favicon_url(clip).present? %>

              <%= image_tag clip_favicon_url(clip),
                  class: "h-8 w-8 rounded-xl object-cover",
                  alt: "" %>

            <% else %>

              <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-slate-800/80 text-sm text-slate-400">
                🌐
              </div>

            <% end %>

            <div class="min-w-0">
              <p class="truncate text-sm font-semibold text-white">
                <%= clip.page_title.presence || clean_clip_title(clip) %>
              </p>

              <% if clip.source_url.present? %>
                <p class="truncate text-xs text-slate-500">
                  <%= clip_domain(clip) %>
                </p>
              <% end %>
            </div>

          <% end %>

        <% end %>

      </div>

    </div>

  </div>

  <!-- CONTENT -->
  <% if ["code", "json", "command"].include?(clip.clip_type.to_s) %>

    <div
      data-controller="code-preview code-highlight"
      data-code-highlight-language-value="<%= (clip.language.presence || clip.clip_type || 'ruby').downcase %>"
      class="relative overflow-hidden rounded-[24px] border border-white/10 bg-[#0B1120] shadow-inner shadow-black/30"
    >

      <!-- Toolbar -->
      <div class="flex items-center justify-between border-b border-white/5 bg-black/20 px-5 py-4 backdrop-blur-xl">

        <div class="min-w-0 flex items-center gap-3">

          <!-- Dots -->
          <div class="flex items-center gap-2">
            <span class="h-3 w-3 rounded-full bg-red-500"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-500"></span>
            <span class="h-3 w-3 rounded-full bg-green-500"></span>
          </div>

          <!-- Language -->
          <span class="rounded-full border border-fuchsia-500/20 bg-fuchsia-500/10 px-2 py-1 text-[10px] font-bold uppercase tracking-[0.14em] text-fuchsia-200">
            <%= clip.language.presence || clip.clip_type.to_s %>
          </span>

          <!-- Title -->
          <p class="truncate text-sm font-semibold text-slate-200">
            <%= clean_clip_title(clip) %>
          </p>

        </div>

        <!-- Toggle -->
        <button
          type="button"
          data-action="click->code-preview#toggle"
          data-code-preview-target="button"
          class="rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-[11px] font-semibold text-slate-300 transition hover:border-fuchsia-500/30 hover:bg-fuchsia-500 hover:text-white"
        >
          Show More
        </button>

      </div>

      <!-- Code -->
      <pre
        data-code-preview-target="content"
        class="scrollbar-thin max-h-72 overflow-auto bg-[#020617] px-6 py-5 font-mono text-[13px] leading-7 text-slate-200 transition-all duration-300"
      ><code data-clip-code><%= clip.content.to_s.strip %></code></pre>

    </div>

  <% else %>

    <!-- Text Content -->
    <div class="rounded-[24px] border border-white/5 bg-black/20 p-5 backdrop-blur-xl">
      <p class="line-clamp-6 whitespace-pre-wrap text-[15px] leading-7 text-slate-300">
        <%= clip.content %>
      </p>
    </div>

  <% end %>

  <!-- FOOTER -->
  <div class="relative z-10 mt-5 border-t border-white/5 pt-5">

    <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">

      <!-- Left -->
      <div class="flex flex-wrap items-center gap-3">

        <!-- Copy -->
        <div data-controller="clips" data-clips-content-value="<%= clip.content %>">

          <%= button_to increment_copy_clip_path(clip),
              method: :patch,
              form: {
                data: {
                  action: "submit->clips#copy"
                }
              },
              class: "inline-flex items-center gap-2 rounded-2xl border border-indigo-500/20 bg-indigo-500/10 px-4 py-2.5 text-xs font-semibold text-indigo-100 transition hover:scale-[1.03] hover:bg-indigo-500 hover:text-white" do %>

            <span>📋</span>
            <span>Copy</span>

          <% end %>

        </div>

        <!-- Copy Count -->
        <span class="inline-flex items-center gap-2 rounded-2xl border border-white/5 bg-black/20 px-4 py-2.5 text-xs text-slate-400">
          <span>⚡</span>
          <span><%= clip.copy_count || 0 %> copies</span>
        </span>

        <!-- Collection -->
        <% if clip.collection.present? %>

          <span class="inline-flex items-center gap-2 rounded-2xl border border-fuchsia-500/20 bg-fuchsia-500/10 px-4 py-2.5 text-xs text-fuchsia-100">
            <span>🗂️</span>
            <span><%= clip.collection.name %></span>
          </span>

        <% end %>

      </div>

      <!-- Right -->
      <div class="flex flex-wrap items-center gap-2">

        <!-- Favorite -->
        <%= button_to toggle_favorite_clip_path(clip),
            method: :patch,
            class: "inline-flex items-center gap-2 rounded-2xl border px-4 py-2 text-xs font-semibold transition-all duration-200 hover:scale-[1.03] #{clip.is_favorite? ? 'border-fuchsia-500/30 bg-fuchsia-500/10 text-fuchsia-200' : 'border-slate-700 bg-slate-950 text-slate-400 hover:bg-slate-800 hover:text-white'}" do %>

          <span><%= clip.is_favorite? ? "★" : "☆" %></span>
          <span><%= clip.is_favorite? ? "Favorited" : "Favorite" %></span>

        <% end %>

        <!-- Pin -->
        <%= button_to toggle_pin_clip_path(clip),
            method: :patch,
            class: "inline-flex items-center gap-2 rounded-2xl border px-4 py-2 text-xs font-semibold transition-all duration-200 hover:scale-[1.03] #{clip.is_pinned? ? 'border-cyan-500/30 bg-cyan-500/10 text-cyan-200' : 'border-slate-700 bg-slate-950 text-slate-400 hover:bg-slate-800 hover:text-white'}" do %>

          <span><%= clip.is_pinned? ? "📌" : "📍" %></span>
          <span><%= clip.is_pinned? ? "Pinned" : "Pin" %></span>

        <% end %>

        <!-- Delete -->
        <%= button_to clip_path(clip),
            method: :delete,
            form: {
              data: {
                turbo_confirm: "Are you sure you want to delete this clip?"
              }
            },
            class: "inline-flex items-center gap-2 rounded-2xl border border-red-500/20 bg-red-500/10 px-4 py-2 text-xs font-semibold text-red-200 transition-all duration-200 hover:scale-[1.03] hover:bg-red-500 hover:text-white" do %>

          <span>🗑️</span>
          <span>Delete</span>

        <% end %>

      </div>

    </div>

    <!-- Collection Form -->
    <% available_collections = local_assigns[:collections] || @collections %>

    <% if available_collections.present? %>

      <div class="mt-5">

        <%= form_with model: clip,
            url: update_collection_clip_path(clip),
            method: :patch,
            class: "grid gap-3 sm:grid-cols-[1fr_130px]" do |form| %>

          <%= form.select :collection_id,
              options_from_collection_for_select(available_collections, :id, :name, clip.collection_id),
              { include_blank: "No Collection" },
              class: "rounded-2xl border border-white/10 bg-black/30 px-4 py-3 text-xs text-white outline-none backdrop-blur-xl focus:border-fuchsia-500" %>

          <%= form.submit "Save",
              class: "cursor-pointer rounded-2xl bg-gradient-to-r from-fuchsia-600 to-indigo-600 px-4 py-3 text-xs font-semibold text-white transition hover:opacity-90" %>

        <% end %>

      </div>

    <% end %>

  </div>

</div>