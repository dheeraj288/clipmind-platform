<div
  id="<%= dom_id(clip) %>"
  class="group relative overflow-hidden rounded-[30px] border border-white/10 bg-[#070A18] p-5 shadow-xl shadow-black/30 transition-all duration-300 hover:-translate-y-1 hover:border-fuchsia-500/30 hover:shadow-fuchsia-950/30"
>

  <div class="pointer-events-none absolute inset-0 opacity-0 transition duration-500 group-hover:opacity-100">
    <div class="absolute -right-20 -top-24 h-56 w-56 rounded-full bg-fuchsia-500/10 blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 h-56 w-56 rounded-full bg-indigo-500/10 blur-3xl"></div>
  </div>

  <!-- Header -->
  <div class="relative z-10 mb-4 flex items-start justify-between gap-4">

    <div class="min-w-0 flex-1">
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <span class="rounded-full border border-indigo-400/20 bg-indigo-500/10 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.18em] text-indigo-200">
          <%= clip.clip_type.to_s.presence || "clip" %>
        </span>

        <% if clip.language.present? %>
          <span class="rounded-full border border-fuchsia-400/20 bg-fuchsia-500/10 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.18em] text-fuchsia-200">
            <%= clip.language %>
          </span>
        <% end %>

        <% if clip.is_pinned? %>
          <span class="rounded-full border border-cyan-400/20 bg-cyan-500/10 px-2.5 py-1 text-[10px] text-cyan-100">
            📌 Pinned
          </span>
        <% end %>

        <span class="text-[11px] text-slate-500">
          <%= time_ago_in_words(clip.created_at) %> ago
        </span>
      </div>

      <% unless ["code", "json", "command"].include?(clip.clip_type.to_s) %>
        <h2 class="line-clamp-1 text-lg font-bold tracking-tight text-white">
          <%= clean_clip_title(clip) %>
        </h2>
      <% end %>
    </div>

    <input
      type="checkbox"
      value="<%= clip.id %>"
      data-bulk-actions-target="checkbox"
      data-action="change->bulk-actions#update"
      class="mt-1 h-4 w-4 rounded border-slate-700 bg-slate-950 accent-fuchsia-600"
    />
  </div>

  <!-- Source Preview -->
  <% if clip.page_title.present? || clip.source_url.present? %>
    <%= link_to clip.source_url.presence || "#",
        target: "_blank",
        rel: "noopener",
        class: "relative z-10 mb-4 flex items-center gap-3 rounded-2xl border border-white/5 bg-white/[0.03] px-4 py-3 transition hover:border-fuchsia-500/20 hover:bg-white/[0.06]" do %>

      <% if clip_favicon_url(clip).present? %>
        <%= image_tag clip_favicon_url(clip), class: "h-9 w-9 rounded-xl object-cover", alt: "" %>
      <% else %>
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-slate-800 text-sm text-slate-400">
          🌐
        </div>
      <% end %>

      <div class="min-w-0">
        <p class="truncate text-sm font-semibold text-white">
          <%= clip.page_title.presence || clean_clip_title(clip) %>
        </p>

        <% if clip.source_url.present? %>
          <p class="truncate text-xs text-slate-500">
            <%= clip_domain(clip) %>
          </p>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <!-- Content -->
  <div class="relative z-10">
    <% if ["code", "json", "command"].include?(clip.clip_type.to_s) %>

      <div
        data-controller="code-preview code-highlight"
        data-code-highlight-language-value="<%= (clip.language.presence || clip.clip_type || 'ruby').downcase %>"
        class="overflow-hidden rounded-[24px] border border-white/10 bg-[#020617]"
      >
        <div class="flex items-center justify-between border-b border-white/5 bg-white/[0.03] px-4 py-3">
          <div class="flex min-w-0 items-center gap-3">
            <div class="flex items-center gap-1.5">
              <span class="h-2.5 w-2.5 rounded-full bg-red-500"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-yellow-500"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-green-500"></span>
            </div>

            <p class="truncate text-xs font-semibold text-slate-300">
              <%= clean_clip_title(clip) %>
            </p>
          </div>

          <button
            type="button"
            data-action="click->code-preview#toggle"
            data-code-preview-target="button"
            class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[11px] font-semibold text-slate-300 transition hover:bg-fuchsia-600 hover:text-white"
          >
            Show More
          </button>
        </div>

        <pre
          data-code-preview-target="content"
          class="scrollbar-thin max-h-72 overflow-auto px-5 py-5 font-mono text-[13px] leading-7 text-slate-200"
        ><code data-clip-code><%= clip.content.to_s.strip %></code></pre>
      </div>

    <% else %>

      <div class="rounded-[24px] border border-white/5 bg-white/[0.03] p-5">
        <p class="line-clamp-6 whitespace-pre-wrap text-[15px] leading-7 text-slate-300">
          <%= clip.content %>
        </p>
      </div>

    <% end %>
  </div>

  <!-- Footer -->
  <div class="relative z-10 mt-5 border-t border-white/5 pt-4">

    <div class="flex items-center justify-between gap-3">

      <!-- Left Meta -->
      <div class="flex min-w-0 flex-wrap items-center gap-2">
        <span class="inline-flex items-center gap-2 rounded-full border border-white/5 bg-white/[0.03] px-3 py-2 text-xs text-slate-400">
          ⚡ <%= clip.copy_count || 0 %>
        </span>

        <% if clip.collection.present? %>
          <span class="inline-flex max-w-[180px] items-center gap-2 rounded-full border border-fuchsia-500/20 bg-fuchsia-500/10 px-3 py-2 text-xs text-fuchsia-100">
            🗂️ <span class="truncate"><%= clip.collection.name %></span>
          </span>
        <% end %>
      </div>

      <!-- Actions -->
        <div class="flex items-center gap-2 opacity-0 transition-all duration-300 group-hover:opacity-100">

        <div data-controller="clips" data-clips-content-value="<%= clip.content %>">
          <%= button_to increment_copy_clip_path(clip),
              method: :patch,
              form: { data: { action: "submit->clips#copy" } },
              class: "inline-flex items-center gap-2 rounded-full bg-gradient-to-r scale-95 group-hover:scale-100 transition-all duration-300 from-fuchsia-600 to-indigo-600 px-4 py-2 text-xs font-bold text-white shadow-lg shadow-fuchsia-950/30 transition hover:scale-105" do %>
            📋 Copy
          <% end %>
        </div>

        <%= button_to toggle_favorite_clip_path(clip),
            method: :patch,
            title: "Favorite",
            class: "flex h-9 w-9 items-center justify-center rounded-full border border-white/10 bg-white/[0.03] text-sm text-slate-300 transition hover:border-fuchsia-500/30 hover:bg-fuchsia-500/10 hover:text-fuchsia-200" do %>
          <%= clip.is_favorite? ? "★" : "☆" %>
        <% end %>

        <%= button_to toggle_pin_clip_path(clip),
            method: :patch,
            title: "Pin",
            class: "flex h-9 w-9 items-center justify-center rounded-full border border-white/10 bg-white/[0.03] text-sm text-slate-300 transition hover:border-cyan-500/30 hover:bg-cyan-500/10 hover:text-cyan-200" do %>
          📌
        <% end %>

        <%= button_to clip_path(clip),
            method: :delete,
            form: { data: { turbo_confirm: "Are you sure you want to delete this clip?" } },
            title: "Delete",
            class: "flex h-9 w-9 items-center justify-center rounded-full border border-white/10 bg-white/[0.03] text-sm text-slate-400 transition hover:border-red-500/30 hover:bg-red-500/10 hover:text-red-200" do %>
          🗑️
        <% end %>

      </div>
    </div>

    <% if clip.related.any? %>
      <div class="mt-4 border-t border-white/5 pt-4">
        <div class="mb-2 text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500">
          Related
        </div>

        <div class="flex flex-wrap gap-2">
          <% clip.related.each do |related| %>
               <%= link_to(
                    clean_clip_title(related),
                    clips_path(anchor: dom_id(related)),
                    class: "rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 text-[11px] text-slate-300 transition hover:border-fuchsia-500/30 hover:bg-fuchsia-500/10 hover:text-white"
                ) %>
          <% end %>
        </div>
      </div>
    <% end %>

    <% available_collections = local_assigns[:collections] || @collections %>

    <% if available_collections.present? %>
      <details class="mt-4">
        <summary class="cursor-pointer text-xs font-semibold text-slate-500 transition hover:text-slate-300">
          Change collection
        </summary>

        <div class="mt-3">
          <%= form_with model: clip,
              url: update_collection_clip_path(clip),
              method: :patch,
              class: "grid gap-3 sm:grid-cols-[1fr_90px]" do |form| %>

            <%= form.select :collection_id,
                options_from_collection_for_select(available_collections, :id, :name, clip.collection_id),
                { include_blank: "No Collection" },
                class: "rounded-2xl border border-white/10 bg-black/30 px-4 py-3 text-xs text-white outline-none focus:border-fuchsia-500" %>

            <%= form.submit "Save",
                class: "cursor-pointer rounded-2xl bg-white/10 px-4 py-3 text-xs font-semibold text-white transition hover:bg-fuchsia-600" %>

          <% end %>
        </div>
      </details>
    <% end %>

  </div>
</div>