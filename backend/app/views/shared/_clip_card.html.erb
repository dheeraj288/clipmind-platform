<div class="rounded-3xl border border-slate-800 bg-slate-900 p-5">
  <div class="mb-3 flex items-start justify-between gap-4">
    <div>
      <h3 class="text-base font-bold text-white">
        <%= clip.title.presence || clip.clip_type.to_s.titleize %>
      </h3>

      <p class="mt-1 text-xs text-slate-500">
        <%= time_ago_in_words(clip.created_at) %> ago
      </p>
    </div>

    <div class="flex items-center gap-2">
      <% if clip.is_favorite? %>
        <span class="text-lg">⭐</span>
      <% end %>

      <span class="rounded-full border border-slate-700 px-3 py-1 text-xs text-slate-400">
        <%= clip.clip_type %>
      </span>
    </div>
  </div>

  <% if ["code", "json", "command"].include?(clip.clip_type.to_s) %>
    <pre class="overflow-x-auto rounded-2xl border border-slate-800 bg-slate-950 p-4 text-sm leading-6 text-slate-300"><code><%= clip.content %></code></pre>
  <% else %>
    <p class="rounded-2xl border border-slate-800 bg-slate-950 p-4 text-sm leading-6 text-slate-300">
      <%= clip.content %>
    </p>
  <% end %>

  <div class="mt-4 flex flex-wrap gap-2">
    <button
      type="button"
      data-controller="clips"
      data-action="click->clips#copy"
      data-clips-content-value="<%= clip.content %>"
      class="rounded-xl border border-slate-700 px-4 py-2 text-xs font-semibold text-slate-300 hover:bg-slate-800">
      Copy
    </button>

    <span class="rounded-xl border border-slate-800 px-4 py-2 text-xs text-slate-500">
      Copies: <%= clip.copy_count || 0 %>
    </span>
  </div>
</div>