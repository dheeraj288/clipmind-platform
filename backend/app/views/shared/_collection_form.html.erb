<div id="collection_form" class="rounded-[30px] border border-white/10 bg-white/[0.04] p-5 shadow-2xl shadow-black/10 backdrop-blur-xl">
  <div class="mb-4 flex items-center gap-3">
    <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-fuchsia-500/10 text-xl text-fuchsia-200">＋</div>
    <div>
      <h2 class="text-lg font-black text-white">Create Collection</h2>
      <p class="text-sm text-slate-500">Make a clean workspace for related clips.</p>
    </div>
  </div>

  <%= form_with model: collection,
      url: collections_path,
      method: :post,
      local: true,
      data: { turbo: false },
      class: "grid gap-3 lg:grid-cols-[1fr_150px]" do |form| %>

    <%= form.text_field :name,
        placeholder: "Collection name...",
        class: "min-h-12 rounded-2xl border border-white/10 bg-slate-950/70 px-4 text-sm font-medium text-white outline-none placeholder:text-slate-500 transition focus:border-fuchsia-400/40 focus:ring-4 focus:ring-fuchsia-500/10" %>

    <%= form.submit "Create",
        class: "min-h-12 cursor-pointer rounded-2xl bg-gradient-to-r from-fuchsia-600 to-indigo-600 px-4 text-sm font-black text-white shadow-lg shadow-fuchsia-950/30 transition hover:-translate-y-0.5 hover:opacity-95" %>
  <% end %>
</div>
