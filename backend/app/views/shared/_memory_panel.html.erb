<div class="sticky top-24 space-y-5">
  <div class="rounded-[28px] border border-white/10 bg-[#070A18] p-5">
    <h3 class="mb-5 text-sm font-bold text-white">
      Today's Memory
    </h3>
    <div class="grid grid-cols-2 gap-3">
      <div class="rounded-2xl bg-indigo-500/10 p-4">
        <p class="text-2xl font-bold text-white">
          <%= @memory_stats[:total] %>
        </p>
        <p class="mt-1 text-xs text-slate-400">
          Total
        </p>
      </div>

      <div class="rounded-2xl bg-fuchsia-500/10 p-4">
        <p class="text-2xl font-bold text-white">
          <%= @memory_stats[:code] %>
        </p>
        <p class="mt-1 text-xs text-slate-400">
          Code
        </p>
      </div>

      <div class="rounded-2xl bg-cyan-500/10 p-4">
        <p class="text-2xl font-bold text-white">
          <%= @memory_stats[:links] %>
        </p>
        <p class="mt-1 text-xs text-slate-400">
          Links
        </p>
      </div>

      <div class="rounded-2xl bg-emerald-500/10 p-4">
        <p class="text-2xl font-bold text-white">
          <%= @memory_stats[:commands] %>
        </p>
        <p class="mt-1 text-xs text-slate-400">
          Commands
        </p>
      </div>

    </div>

  </div>
  <!-- Top tags -->
  <div class="rounded-[28px] border border-white/10 bg-[#070A18] p-5">
    <h3 class="mb-4 text-sm font-bold text-white">
      Top Topics
    </h3>

    <div class="flex flex-wrap gap-2">
      <% @top_tags.each do |tag,count| %>
        <span class="rounded-full bg-fuchsia-500/10 px-3 py-2 text-xs text-fuchsia-200">
          #<%= tag %>
        </span>
      <% end %>
    </div>
  </div>
  
  <div class="mb-6 rounded-3xl border border-fuchsia-500/10 bg-[#0B1020] p-5">
  <h2 class="mb-5 text-lg font-bold text-white">
    AI Insights
  </h2>
  <div class="space-y-4">
    <div>
      <p class="text-xs text-slate-500">
        Clips Today
      </p>
      <p class="mt-1 font-semibold text-white">
        🧠 <%= @insights[:total_clips] %>
      </p>
    </div>

    <div>
      <p class="text-xs text-slate-500">
        Top Topics
      </p>
      <div class="mt-2 flex flex-wrap gap-2">
        <% @insights[:top_tags].each do |tag| %>
          <span class="rounded-full bg-fuchsia-500/10 px-3 py-1 text-xs text-fuchsia-300">
            #<%= tag %>
          </span>
        <% end %>
      </div>
    </div>

    <div>
      <p class="text-xs text-slate-500">
        Learning Pattern
      </p>

      <p class="mt-1 text-sm text-slate-300">
        <%= @insights[:learning_pattern] %>
      </p>
    </div>

    <div>
      <p class="text-xs text-slate-500">
        Peak Activity
      </p>

      <p class="mt-1 text-sm text-white">
        ⚡ <%= @insights[:peak_time] %>
      </p>
    </div>
  </div>
</div>
  <!-- Recent -->
  <div class="rounded-[28px] border border-white/10 bg-[#070A18] p-5">

    <h3 class="mb-4 text-sm font-bold text-white">
      Recent Memory
    </h3>

    <div class="space-y-3">
      <% @recent_memory.each do |clip| %>
      <div class="rounded-xl bg-white/[0.03] p-3">
        <div class="text-xs text-slate-500">
          <%= time_ago_in_words(clip.created_at) %> ago
        </div>
        <div class="mt-1 line-clamp-2 text-sm text-slate-300">
          <%= truncate(clip.content,length:70) %>
        </div>
      </div>
      <% end %>
    </div>
  </div>
</div>