<div class="rounded-[32px] border border-dashed border-white/12 bg-white/[0.035] px-8 py-14 text-center shadow-2xl shadow-black/10 backdrop-blur-xl">
  <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-3xl border border-white/10 bg-white/[0.06] text-4xl shadow-lg shadow-black/20">
    <%= icon || "📭" %>
  </div>

  <h3 class="mt-5 text-xl font-black tracking-tight text-white">
    <%= title %>
  </h3>

  <p class="mx-auto mt-2 max-w-md text-sm leading-6 text-slate-400">
    <%= message %>
  </p>
</div>
